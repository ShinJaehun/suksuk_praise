<%= form_with model: [:admin, school],
      class: "space-y-4",
      data: { turbo_frame: "_top" } do |f| %>
  <div>
    <% name_has_errors = school.errors[:name].any? %>
    <%= f.label :name, "학교 이름", class: "block text-sm font-semibold text-slate-800" %>
    <%= f.text_field :name,
          autofocus: true,
          class: "mt-1 block w-full rounded-lg border px-3 py-2 text-sm text-slate-900 shadow-sm focus:outline-none focus:ring-2 #{name_has_errors ? "border-rose-400 focus:border-rose-500 focus:ring-rose-100" : "border-slate-300 focus:border-sky-500 focus:ring-sky-100"}" %>
    <% if name_has_errors %>
      <p class="mt-1 text-sm text-rose-600">
        <%= school.errors.added?(:name, :blank) ? t("admin.schools.errors.name_blank") : school.errors.full_messages_for(:name).to_sentence %>
      </p>
    <% end %>
  </div>

  <div class="flex justify-end">
    <%= f.submit submit_label,
          data: { turbo_submits_with: school.new_record? ? "등록 중..." : "저장 중..." },
          class: "inline-flex items-center justify-center rounded-lg bg-blue-600 px-4 py-2 text-sm font-semibold text-white hover:bg-blue-700" %>
  </div>
<% end %>
