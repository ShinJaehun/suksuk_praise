<% if turbo_frame_request? %>
  <%= render "modal", school: @school, title: t("admin.schools.edit_title"), submit_label: t("admin.schools.form.update_submit") %>
<% else %>
  <section class="mx-auto w-full max-w-xl space-y-4 pt-4">
    <div class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm">
      <div class="space-y-4">
        <%= render "content", school: @school, title: t("admin.schools.edit_title"), submit_label: t("admin.schools.form.update_submit") %>
      </div>
      <%= link_to t("admin.schools.actions.back_to_schools"), schools_path, class: "mt-4 inline-block text-sm text-blue-600 hover:underline" %>
    </div>
  </section>
<% end %>
