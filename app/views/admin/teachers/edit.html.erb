<section class="mx-auto w-full max-w-6xl pt-4 space-y-6">
<h1 class="text-2xl font-extrabold tracking-tight text-slate-900">담임 교실 배정</h1>

<div class="p-5 bg-white rounded-2xl border border-slate-200 shadow-sm text-sm">
  <h2 class="text-base font-semibold mb-2">교사 정보</h2>
  <div class="flex items-center gap-3 mb-3">
    <%= user_avatar_image(
          @teacher,
          size: 128,
          class: "h-20 w-20 rounded-xl object-cover border border-slate-200 bg-slate-100",
          alt: "#{@teacher.name} avatar"
        ) %>
    <div class="space-y-1">
      <p>
        <span class="font-medium text-gray-700">이름:</span>
        <span class="ml-2"><%= @teacher.name %></span>
      </p>
      <p>
        <span class="font-medium text-gray-700">이메일:</span>
        <span class="ml-2"><%= @teacher.email %></span>
      </p>
      <p>
        <span class="font-medium text-gray-700">생성일:</span>
        <span class="ml-2"><%= l(@teacher.created_at, format: :short) %></span>
      </p>
      <p>
        <span class="font-medium text-gray-700">담당 교실 수:</span>
        <span class="ml-2"><%= @teacher_classroom_count %>개</span>
      </p>
      <p>
        <span class="font-medium text-gray-700">담당 교실:</span>
        <span class="ml-2"><%= @teacher_classroom_names.any? ? @teacher_classroom_names.join(", ") : "미배정" %></span>
      </p>
    </div>
  </div>
</div>

<div class="p-5 bg-white rounded-2xl border border-slate-200 shadow-sm text-sm">
  <h2 class="text-base font-semibold mb-3">담임 교실 선택</h2>

  <%= form_with model: @teacher,
                url: admin_teacher_path(@teacher),
                method: :patch,
                local: true do |f| %>

    <% if @classrooms.none? %>
      <p class="text-xs text-gray-500 mb-4">
        아직 생성된 교실이 없습니다. 먼저 교실을 만든 뒤, 담임 교실을 지정할 수 있습니다.
      </p>
    <% else %>
      <div class="space-y-2 mb-4">
        <% @classrooms.each do |classroom| %>
          <label class="flex items-center space-x-2">
            <%= check_box_tag "classroom_ids[]",
                              classroom.id,
                              @teacher_classroom_ids.include?(classroom.id),
                              class: "rounded border-gray-300" %>
            <span><%= classroom.name %></span>
          </label>
        <% end %>
      </div>
    <% end %>

    <div class="mt-4 flex flex-col gap-2 sm:flex-row sm:items-center">
      <%= f.submit "저장",
                   class: "inline-flex justify-center rounded-lg bg-blue-600 px-4 py-2 text-sm font-semibold text-white hover:bg-blue-700" %>
      <%= link_to "교실로 돌아가기",
                  classrooms_path,
                  class: "inline-flex justify-center rounded-lg border border-slate-200 px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-50" %>
    </div>
  <% end %>
</div>
</section>
