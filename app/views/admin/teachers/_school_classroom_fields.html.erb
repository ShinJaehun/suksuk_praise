<div data-controller="teacher-school-classrooms">
  <div>
    <%= label_tag :teacher_assignment_school_id, t("admin.teachers.form.school_label"), class: "block text-sm font-medium text-gray-700" %>
    <%= select_tag :school_id,
          options_from_collection_for_select(@schools, :id, :name, @selected_school_id),
          include_blank: t("admin.teachers.form.school_unspecified"),
          id: "teacher_assignment_school_id",
          class: "mt-1 block w-full rounded border border-gray-300 px-3 py-2",
          data: {
            teacher_school_classrooms_target: "school",
            action: "teacher-school-classrooms#update"
          } %>
  </div>

  <fieldset class="mt-5">
    <legend class="text-sm font-semibold text-slate-800"><%= t("admin.teachers.form.classrooms_label") %></legend>
    <%= hidden_field_tag "classroom_ids[]", "" %>
    <p class="mt-1 text-sm text-slate-500"><%= t("admin.teachers.form.classrooms_help") %></p>

    <% @schools.each do |school| %>
      <div class="mt-3 grid gap-2 sm:grid-cols-2"
           data-teacher-school-classrooms-target="group"
           data-school-id="<%= school.id %>"
           <%= "hidden" unless @selected_school_id == school.id %>>
        <% classrooms = @classrooms_by_school.fetch(school.id, []) %>
        <% if classrooms.any? %>
          <% classrooms.each do |classroom| %>
            <label class="flex items-center gap-2 rounded-lg border border-slate-200 px-3 py-2 text-sm text-slate-700">
              <%= check_box_tag "classroom_ids[]",
                    classroom.id,
                    @selected_classroom_ids.include?(classroom.id),
                    disabled: @selected_school_id != school.id,
                    class: "rounded border-slate-300 text-blue-600 focus:ring-blue-500" %>
              <span><%= classroom.name %></span>
            </label>
          <% end %>
        <% else %>
          <p class="text-sm text-slate-500"><%= t("admin.teachers.form.classrooms_empty") %></p>
        <% end %>
      </div>
    <% end %>
  </fieldset>
</div>
