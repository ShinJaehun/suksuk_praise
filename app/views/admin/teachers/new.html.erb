<% if turbo_frame_request? %>
  <%= render "new_modal" %>
<% else %>
  <section class="mx-auto w-full max-w-6xl pt-4">
    <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
      <h1 class="mb-4 text-2xl font-extrabold tracking-tight text-slate-900">새 교사 추가</h1>
      <%= render "form", teacher: @teacher %>
      <div class="mt-4">
        <%= link_to "교실로 돌아가기", classrooms_path, class: "text-blue-600 hover:underline" %>
      </div>
    </div>
  </section>
<% end %>
