<h1 class="text-2xl font-extrabold tracking-tight text-slate-900">교사 소속 및 담당 교실</h1>

<% if @teacher.errors.any? %>
  <div class="rounded-lg border border-rose-200 bg-rose-50 px-3 py-2 text-sm text-rose-700">
    <%= @teacher.errors.full_messages.to_sentence %>
  </div>
<% end %>

<div class="rounded-2xl border border-slate-200 bg-white p-5 text-sm shadow-sm">
  <h2 class="mb-2 text-base font-semibold">교사 정보</h2>
  <div class="flex items-center gap-3">
    <%= user_avatar_image(
          @teacher,
          size: 128,
          class: "h-20 w-20 rounded-xl border border-slate-200 bg-slate-100 object-cover",
          alt: "#{@teacher.name} avatar"
        ) %>
    <div class="space-y-1">
      <p><span class="font-medium text-gray-700">이름:</span> <span class="ml-2"><%= @teacher.name %></span></p>
      <p><span class="font-medium text-gray-700">이메일:</span> <span class="ml-2"><%= @teacher.email %></span></p>
      <p><span class="font-medium text-gray-700">생성일:</span> <span class="ml-2"><%= l(@teacher.created_at, format: :short) %></span></p>
      <p><span class="font-medium text-gray-700">담당 교실 수:</span> <span class="ml-2"><%= @teacher_classroom_count %>개</span></p>
      <p><span class="font-medium text-gray-700">담당 교실:</span> <span class="ml-2"><%= @teacher_classroom_names.any? ? @teacher_classroom_names.join(", ") : "미배정" %></span></p>
    </div>
  </div>
</div>

<%= form_with model: @teacher,
      url: admin_teacher_path(@teacher),
      method: :patch,
      class: "space-y-6",
      data: { turbo_frame: "_top" } do |f| %>
  <section class="rounded-2xl border border-slate-200 bg-white p-5 text-sm shadow-sm">
    <h2 class="mb-3 text-base font-semibold">학교 소속</h2>
    <%= label_tag :school_id, "학교", class: "block text-sm font-medium text-gray-700" %>
    <%= select_tag :school_id,
          options_from_collection_for_select(@schools, :id, :name, @selected_school_id),
          include_blank: "학교 미지정",
          class: "mt-1 block w-full rounded border border-gray-300 px-3 py-2 sm:max-w-md" %>
  </section>

  <section class="rounded-2xl border border-slate-200 bg-white p-5 text-sm shadow-sm">
    <h2 class="mb-3 text-base font-semibold">담당 교실 선택</h2>
    <%= hidden_field_tag "classroom_ids[]", "" %>

    <% if @classrooms.none? %>
      <p class="mb-4 text-xs text-gray-500">아직 생성된 교실이 없습니다. 먼저 교실을 만든 뒤, 담당 교실을 지정할 수 있습니다.</p>
    <% else %>
      <div class="mb-4 space-y-2">
        <% @classrooms.each do |classroom| %>
          <label class="flex items-start gap-2 rounded-lg border border-slate-100 px-3 py-2">
            <%= check_box_tag "classroom_ids[]",
                  classroom.id,
                  @teacher_classroom_ids.include?(classroom.id),
                  class: "mt-1 rounded border-gray-300" %>
            <span class="min-w-0">
              <span class="block text-sm font-medium text-slate-800"><%= classroom.name %></span>
              <span class="block text-xs text-slate-500">
                <%= classroom.school&.name || "학교 미지정" %> · <%= classroom.grade ? "#{classroom.grade}학년" : "학년 미지정" %>
              </span>
            </span>
          </label>
        <% end %>
      </div>
    <% end %>

    <div class="flex flex-col gap-2 sm:flex-row sm:items-center">
      <%= f.submit "저장", class: "inline-flex justify-center rounded-lg bg-blue-600 px-4 py-2 text-sm font-semibold text-white hover:bg-blue-700" %>
      <%= link_to "교실로 돌아가기", classrooms_path, class: "inline-flex justify-center rounded-lg border border-slate-200 px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-50" %>
    </div>
  </section>
<% end %>
