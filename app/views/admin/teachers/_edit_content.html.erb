<h1 class="text-2xl font-extrabold tracking-tight text-slate-900"><%= t("admin.teachers.edit_title") %></h1>

<% if @teacher.errors.any? %>
  <div class="rounded-lg border border-rose-200 bg-rose-50 px-3 py-2 text-sm text-rose-700">
    <%= @teacher.errors.full_messages.to_sentence %>
  </div>
<% end %>

<div class="rounded-2xl border border-slate-200 bg-white p-5 text-sm shadow-sm">
  <h2 class="mb-2 text-base font-semibold"><%= t("admin.teachers.info_title") %></h2>
  <div class="flex items-center gap-3">
    <%= user_avatar_image(
          @teacher,
          size: 128,
          class: "h-20 w-20 rounded-xl border border-slate-200 bg-slate-100 object-cover",
          alt: "#{@teacher.name} avatar"
        ) %>
    <div class="space-y-1">
      <p><span class="font-medium text-gray-700"><%= t("ui.user_labels.name") %>:</span> <span class="ml-2"><%= @teacher.name %></span></p>
      <p><span class="font-medium text-gray-700"><%= t("ui.user_labels.email") %>:</span> <span class="ml-2"><%= @teacher.email %></span></p>
      <p><span class="font-medium text-gray-700"><%= t("admin.teachers.info.created_at") %></span> <span class="ml-2"><%= l(@teacher.created_at, format: :short) %></span></p>
      <p><span class="font-medium text-gray-700"><%= t("admin.teachers.info.classroom_count") %></span> <span class="ml-2"><%= t("admin.teachers.info.classroom_count_value", count: @teacher_classroom_count) %></span></p>
      <p><span class="font-medium text-gray-700"><%= t("admin.teachers.info.classrooms") %></span> <span class="ml-2"><%= @teacher_classroom_names.any? ? @teacher_classroom_names.join(", ") : t("admin.teachers.info.unassigned") %></span></p>
    </div>
  </div>
</div>

<%= form_with model: @teacher,
      url: admin_teacher_path(@teacher),
      method: :patch,
      class: "space-y-6",
      data: { turbo_frame: "_top" } do |f| %>
  <section class="rounded-2xl border border-slate-200 bg-white p-5 text-sm shadow-sm">
    <h2 class="mb-3 text-base font-semibold"><%= t("admin.teachers.school_membership_title") %></h2>
    <%= label_tag :school_id, t("admin.teachers.form.school_label"), class: "block text-sm font-medium text-gray-700" %>
    <%= select_tag :school_id,
          options_from_collection_for_select(@schools, :id, :name, @selected_school_id),
          include_blank: t("admin.teachers.form.school_unspecified"),
          class: "mt-1 block w-full rounded border border-gray-300 px-3 py-2 sm:max-w-md" %>

    <p class="mt-3 text-sm text-slate-500"><%= t("admin.teachers.assignment_managed_in_school") %></p>
    <% if @teacher.school_membership %>
      <%= link_to t("admin.teachers.manage_school_teachers"),
            school_teachers_path(@teacher.school_membership.school),
            data: { turbo_frame: "_top" },
            class: "mt-2 inline-flex font-semibold text-sky-700 underline hover:text-sky-900" %>
    <% end %>

    <div class="mt-5 flex flex-col gap-2 sm:flex-row sm:items-center">
      <%= f.submit t("ui.save"),
            data: { turbo_submits_with: t("admin.teachers.form.submitting") },
            class: "inline-flex justify-center rounded-lg bg-blue-600 px-4 py-2 text-sm font-semibold text-white hover:bg-blue-700" %>
      <%= link_to t("admin.teachers.back_to_index"),
            admin_teachers_path,
            data: { turbo_frame: "_top" },
            class: "inline-flex justify-center rounded-lg border border-slate-200 px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-50" %>
    </div>
  </section>
<% end %>
