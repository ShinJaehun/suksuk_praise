<section class="mx-auto w-full max-w-6xl pt-4 space-y-4">
  <div class="flex flex-col items-start justify-between gap-3 sm:flex-row sm:items-center">
    <h1 class="text-2xl font-extrabold tracking-tight text-slate-900">교사 관리</h1>
    <%= link_to "새 교사 추가", new_admin_teacher_path,
                class: "inline-flex items-center rounded-lg bg-blue-600 px-4 py-2 text-sm font-semibold text-white hover:bg-blue-700" %>
  </div>

  <div class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm">
    <div class="overflow-x-auto">
    <table class="min-w-[760px] w-full text-sm">
      <thead class="bg-slate-100 text-slate-600 uppercase text-xs">
        <tr>
          <th class="px-4 py-3 text-left">교사</th>
          <th class="px-4 py-3 text-left">이메일</th>
          <th class="px-4 py-3 text-left">생성일</th>
          <th class="px-4 py-3 text-left">담임 교실</th>
          <th class="px-4 py-3 text-right">교실 수</th>
          <th class="px-4 py-3 text-right"></th>
        </tr>
      </thead>
      <tbody>
        <% @rows.each do |row| %>
          <% t = row.teacher %>
          <tr class="border-t border-slate-100">
            <td class="px-4 py-3">
              <div class="flex items-center gap-2">
                <%= user_avatar_image(
                      t,
                      size: 128,
                      class: "h-9 w-9 rounded-xl object-cover border border-slate-200 bg-slate-100",
                      alt: "#{t.name} avatar"
                    ) %>
                <span class="font-medium text-slate-800"><%= t.name %></span>
              </div>
            </td>
            <td class="px-4 py-3"><%= t.email %></td>
            <td class="px-4 py-3"><%= l(t.created_at, format: :short) %></td>
            <td class="px-4 py-3">
              <% if row.homeroom_names.any? %>
                <%= row.homeroom_names.join(", ") %>
              <% else %>
                <span class="text-slate-500 text-xs">지정 없음</span>
              <% end %>
            </td>
            <td class="px-4 py-3 text-right"><%= row.classroom_count %></td>
            <td class="px-4 py-3 text-right">
              <%= link_to "수정",
                    edit_admin_teacher_path(t),
                    class: "inline-flex items-center rounded-md border border-sky-300 bg-sky-50 px-3 py-1.5 text-xs font-semibold text-sky-700 hover:bg-sky-100" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
    </div>
  </div>
</section>
