<section class="mx-auto w-full max-w-4xl space-y-6 pt-4">
  <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
    <div class="space-y-1">
      <h1 class="text-2xl font-extrabold tracking-tight text-slate-900"><%= t("compliment_presets.index.title") %></h1>
      <p class="text-sm text-slate-600"><%= t("compliment_presets.index.description") %></p>
    </div>
  </div>

  <section class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
    <h2 class="text-base font-semibold text-slate-900"><%= t("compliment_presets.index.form_title") %></h2>

    <%= form_with model: @compliment_preset, url: compliment_presets_path, class: "mt-4 space-y-3" do |f| %>
      <% if @compliment_preset.errors.any? %>
        <div class="rounded-lg border border-rose-200 bg-rose-50 px-3 py-2 text-sm font-medium text-rose-700">
          <%= @compliment_preset.errors.full_messages.to_sentence %>
        </div>
      <% end %>

      <div>
        <%= f.label :title, t("compliment_presets.form.title"), class: "mb-2 block text-sm font-medium text-slate-700" %>
        <%= f.text_field :title,
              maxlength: 50,
              required: true,
              class: "block w-full rounded-xl border border-slate-300 px-4 py-3 text-sm text-slate-900 shadow-sm placeholder:text-slate-400 focus:border-sky-500 focus:outline-none focus:ring-2 focus:ring-sky-100",
              placeholder: t("compliment_presets.form.placeholder") %>
      </div>

      <div class="flex justify-end">
        <%= f.submit t("compliment_presets.form.create"),
              class: "inline-flex items-center justify-center rounded-lg bg-emerald-600 px-4 py-2 text-sm font-semibold text-white hover:bg-emerald-700" %>
      </div>
    <% end %>
  </section>

  <section class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm">
    <div class="border-b border-slate-100 px-5 py-4">
      <h2 class="text-base font-semibold text-slate-900"><%= t("compliment_presets.index.list_title") %></h2>
    </div>

    <% if @compliment_presets.any? %>
      <div class="divide-y divide-slate-100">
        <% @compliment_presets.each do |preset| %>
          <div class="flex flex-col gap-3 px-5 py-4 sm:flex-row sm:items-center sm:justify-between">
            <div class="min-w-0">
              <p class="break-words text-sm font-semibold text-slate-900"><%= preset.title %></p>
            </div>
            <div class="flex shrink-0 gap-2">
              <%= link_to t("ui.edit"),
                    edit_compliment_preset_path(preset),
                    class: "inline-flex items-center justify-center rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-50" %>
              <%= button_to t("ui.delete"),
                    compliment_preset_path(preset),
                    method: :delete,
                    data: { turbo_confirm: t("compliment_presets.destroy.confirm") },
                    class: "inline-flex items-center justify-center rounded-lg border border-rose-300 bg-white px-3 py-2 text-sm font-semibold text-rose-700 hover:bg-rose-50" %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="px-5 py-8 text-center text-sm text-slate-500">
        <%= t("compliment_presets.index.empty") %>
      </div>
    <% end %>
  </section>
</section>
