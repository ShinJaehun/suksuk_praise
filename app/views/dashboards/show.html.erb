<section class="mx-auto w-full max-w-6xl space-y-6 px-4 py-6 sm:px-6 lg:px-8">
  <% if current_user.student? %>
    <div>
      <h1 class="text-2xl font-extrabold tracking-tight text-slate-900">한눈에 보기</h1>
    </div>

    <nav class="flex items-center justify-between gap-4" aria-label="주간 이동">
      <%= link_to dashboard_path(week_offset: @week_offset - 1),
            aria: { label: "이전 주 보기" },
            class: "inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-slate-100 text-xl font-bold text-slate-700 hover:bg-slate-200" do %>
        ←
      <% end %>
      <p class="text-center text-2xl font-extrabold text-slate-800 sm:text-3xl">
        <%= @week_start.strftime("%Y.%m.%d") %> ~ <%= @week_end.strftime("%Y.%m.%d") %>
      </p>
      <%= link_to dashboard_path(week_offset: @week_offset + 1),
            aria: { label: "다음 주 보기" },
            class: "inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-slate-100 text-xl font-bold text-slate-700 hover:bg-slate-200" do %>
        →
      <% end %>
    </nav>

    <div class="overflow-x-auto">
      <div class="min-w-[760px] rounded-xl border border-slate-200 bg-white shadow-sm">
        <dl class="grid divide-x divide-slate-200" style="grid-template-columns: repeat(5, minmax(0, 1fr));">
          <% [
            ["total-praise", "지금까지 받은 칭찬", @student_dashboard_summary[:total_praise_count]],
            ["weekly-praise", "일주일 동안 받은 칭찬", @student_dashboard_summary[:weekly_praise_count]],
            ["held-coupons", "보유 쿠폰", @student_dashboard_summary[:held_coupon_count]],
            ["weekly-issued-coupons", "일주일 동안 받은 쿠폰", @student_dashboard_summary[:weekly_issued_coupon_count]],
            ["weekly-used-coupons", "일주일 동안 사용한 쿠폰", @student_dashboard_summary[:weekly_used_coupon_count]]
          ].each do |key, label, count| %>
            <div class="px-4 py-3"
                 data-summary="<%= key %>"
                 data-count="<%= count %>">
              <dt class="text-xs font-medium leading-tight text-slate-500"><%= label %></dt>
              <dd class="mt-1 text-lg font-extrabold text-slate-900"><%= count %></dd>
            </div>
          <% end %>
        </dl>
      </div>
    </div>

    <article class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm sm:p-6">
      <div class="overflow-x-auto rounded-xl bg-gradient-to-b from-blue-50 to-white px-3 py-4">
        <svg viewBox="0 0 500 190"
             class="h-auto min-w-[560px] w-full"
             role="img"
             aria-label="월요일부터 금요일까지 받은 칭찬과 쿠폰 활동 그래프">
          <% @y_axis_ticks.reverse_each do |tick| %>
            <line x1="35"
                  y1="<%= tick[:y] %>"
                  x2="470"
                  y2="<%= tick[:y] %>"
                  stroke="#dbeafe"
                  stroke-width="<%= tick[:value].zero? ? 2 : 1 %>"
                  data-grid-line="<%= tick[:value] %>" />
            <% unless @weekly_activity_empty %>
              <text x="27"
                    y="<%= tick[:y] + 4 %>"
                    text-anchor="end"
                    fill="#94a3b8"
                    class="text-[10px] font-semibold"
                    data-y-axis-tick="<%= tick[:value] %>">
                <%= tick[:value] %>
              </text>
            <% end %>
          <% end %>
          <% unless @weekly_activity_empty %>
            <path
              d="<%= @weekly_praise_path %>"
              fill="none"
              stroke="#3b82f6"
              stroke-width="5"
              stroke-linecap="round"
              stroke-linejoin="round"
              data-graph-series="praise"
            />
          <% end %>

          <% @weekly_activity.each do |activity| %>
            <g data-graph-weekday="<%= activity[:label] %>"
               data-graph-date="<%= activity[:date].strftime("%-m/%-d") %>"
               data-praise-count="<%= activity[:praise_count] %>"
               data-issued-coupon-count="<%= activity[:issued_coupon_count] %>"
               data-used-coupon-count="<%= activity[:used_coupon_count] %>">
              <title><%= activity[:label] %>요일 받은 칭찬 <%= activity[:praise_count] %>개</title>
              <% unless @weekly_activity_empty %>
                <circle cx="<%= activity[:x] %>"
                        cy="<%= activity[:y] %>"
                        r="6"
                        fill="#3b82f6"
                        stroke="#ffffff"
                        stroke-width="3"
                        data-graph-point="praise" />
              <% end %>

              <% marker_y = [activity[:y] - 22, 17].max %>
              <% if activity[:issued_coupon_count].positive? %>
                <text x="<%= activity[:x] - (activity[:used_coupon_count].positive? ? 10 : 0) %>"
                      y="<%= marker_y %>"
                      text-anchor="middle"
                      class="text-[15px]">🎁</text>
              <% end %>
              <% if activity[:used_coupon_count].positive? %>
                <text x="<%= activity[:x] + (activity[:issued_coupon_count].positive? ? 10 : 0) %>"
                      y="<%= marker_y %>"
                      text-anchor="middle"
                      class="text-[15px]">✅</text>
              <% end %>

              <text x="<%= activity[:x] %>"
                    y="145"
                    text-anchor="middle"
                    class="fill-slate-800 text-[11px] font-extrabold">
                <%= activity[:label] %>요일
              </text>
              <text x="<%= activity[:x] %>"
                    y="164"
                    text-anchor="middle"
                    class="fill-slate-500 text-[10px] font-semibold">
                <%= activity[:date].strftime("%-m/%-d") %>
              </text>
            </g>
          <% end %>
        </svg>
      </div>
    </article>
  <% elsif current_user.admin? %>
    <div>
      <h1 class="text-2xl font-extrabold tracking-tight text-slate-900">한눈에 보기</h1>
    </div>

    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      <div class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
        <p class="text-sm font-medium text-slate-500">전체 교실 수</p>
        <p class="mt-2 text-3xl font-bold text-slate-900"><%= @total_classroom_count %></p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
        <p class="text-sm font-medium text-slate-500">전체 교사 수</p>
        <p class="mt-2 text-3xl font-bold text-slate-900"><%= @total_teacher_count %></p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
        <p class="text-sm font-medium text-slate-500">전체 학생 수</p>
        <p class="mt-2 text-3xl font-bold text-slate-900"><%= @total_student_count %></p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
        <p class="text-sm font-medium text-slate-500">pending 쿠폰 요청 수</p>
        <p class="mt-2 text-3xl font-bold text-slate-900"><%= @pending_coupon_request_count %></p>
      </div>
    </div>
  <% else %>
    <div>
      <h1 class="text-2xl font-extrabold tracking-tight text-slate-900">한눈에 보기</h1>
    </div>

    <div class="grid gap-4 md:grid-cols-2">
      <% @classrooms.each do |classroom| %>
        <article class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
          <div class="flex items-start justify-between gap-3">
            <div>
              <h2 class="text-lg font-bold text-slate-900"><%= classroom.name %></h2>
              <p class="mt-1 text-sm text-slate-500">학생 <%= @student_counts_by_classroom_id.fetch(classroom.id, 0) %>명</p>
            </div>
            <%= link_to "교실 열기", classroom_path(classroom), class: "shrink-0 rounded-lg bg-blue-600 px-3 py-2 text-sm font-semibold text-white hover:bg-blue-700" %>
          </div>

          <dl class="mt-4 grid grid-cols-3 gap-3 text-sm">
            <div class="rounded-lg bg-slate-50 p-3">
              <dt class="text-slate-500">오늘 칭찬</dt>
              <dd class="mt-1 text-lg font-bold text-slate-900"><%= @today_compliment_counts_by_classroom_id.fetch(classroom.id, 0) %></dd>
            </div>
            <div class="rounded-lg bg-slate-50 p-3">
              <dt class="text-slate-500">쿠폰 요청</dt>
              <dd class="mt-1 text-lg font-bold text-slate-900"><%= @pending_coupon_request_counts_by_classroom_id.fetch(classroom.id, 0) %></dd>
            </div>
            <div class="rounded-lg bg-slate-50 p-3">
              <dt class="text-slate-500">새 메시지</dt>
              <dd class="mt-1 text-lg font-bold text-slate-900"><%= @unread_student_message_counts_by_classroom_id.fetch(classroom.id, 0) %></dd>
            </div>
          </dl>
        </article>
      <% end %>
    </div>
  <% end %>
</section>
