<section class="mx-auto w-full max-w-6xl space-y-6 px-4 py-6 sm:px-6 lg:px-8">
  <% if current_user.student? %>
    <div>
      <h1 class="text-2xl font-extrabold tracking-tight text-slate-900">한눈에 보기</h1>
    </div>

    <article class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
      <h2 class="text-lg font-bold text-slate-900">이번 주 받은 칭찬</h2>
      <p class="mt-1 text-sm text-slate-500"><%= @classroom.name %></p>

      <div class="mt-5">
        <svg viewBox="0 0 200 110" class="h-auto w-full" role="img" aria-label="월요일부터 금요일까지 받은 칭찬 수 꺾은선 그래프">
          <line x1="20" y1="82" x2="180" y2="82" class="stroke-slate-200" stroke-width="1" />
          <path
            d="<%= @weekly_praise_path %>"
            fill="none"
            class="stroke-blue-500"
            stroke-width="3"
            stroke-linecap="round"
            stroke-linejoin="round"
          />

          <% @weekly_praise_counts.each do |weekday| %>
            <g data-weekday="<%= weekday[:label] %>" data-count="<%= weekday[:count] %>">
              <circle cx="<%= weekday[:x] %>" cy="<%= weekday[:y] %>" r="4" class="fill-blue-500 stroke-white" stroke-width="2" />
              <text x="<%= weekday[:x] %>" y="<%= weekday[:y] - 8 %>" text-anchor="middle" class="fill-slate-900 text-[8px] font-bold"><%= weekday[:count] %></text>
              <text x="<%= weekday[:x] %>" y="100" text-anchor="middle" class="fill-slate-600 text-[8px] font-semibold"><%= weekday[:label] %></text>
            </g>
          <% end %>
        </svg>
      </div>
    </article>
  <% elsif current_user.admin? %>
    <div>
      <h1 class="text-2xl font-extrabold tracking-tight text-slate-900">한눈에 보기</h1>
    </div>

    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      <div class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
        <p class="text-sm font-medium text-slate-500">전체 교실 수</p>
        <p class="mt-2 text-3xl font-bold text-slate-900"><%= @total_classroom_count %></p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
        <p class="text-sm font-medium text-slate-500">전체 교사 수</p>
        <p class="mt-2 text-3xl font-bold text-slate-900"><%= @total_teacher_count %></p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
        <p class="text-sm font-medium text-slate-500">전체 학생 수</p>
        <p class="mt-2 text-3xl font-bold text-slate-900"><%= @total_student_count %></p>
      </div>
      <div class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
        <p class="text-sm font-medium text-slate-500">pending 쿠폰 요청 수</p>
        <p class="mt-2 text-3xl font-bold text-slate-900"><%= @pending_coupon_request_count %></p>
      </div>
    </div>
  <% else %>
    <div>
      <h1 class="text-2xl font-extrabold tracking-tight text-slate-900">한눈에 보기</h1>
    </div>

    <div class="grid gap-4 md:grid-cols-2">
      <% @classrooms.each do |classroom| %>
        <article class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
          <div class="flex items-start justify-between gap-3">
            <div>
              <h2 class="text-lg font-bold text-slate-900"><%= classroom.name %></h2>
              <p class="mt-1 text-sm text-slate-500">학생 <%= @student_counts_by_classroom_id.fetch(classroom.id, 0) %>명</p>
            </div>
            <%= link_to "교실 열기", classroom_path(classroom), class: "shrink-0 rounded-lg bg-blue-600 px-3 py-2 text-sm font-semibold text-white hover:bg-blue-700" %>
          </div>

          <dl class="mt-4 grid grid-cols-3 gap-3 text-sm">
            <div class="rounded-lg bg-slate-50 p-3">
              <dt class="text-slate-500">오늘 칭찬</dt>
              <dd class="mt-1 text-lg font-bold text-slate-900"><%= @today_compliment_counts_by_classroom_id.fetch(classroom.id, 0) %></dd>
            </div>
            <div class="rounded-lg bg-slate-50 p-3">
              <dt class="text-slate-500">쿠폰 요청</dt>
              <dd class="mt-1 text-lg font-bold text-slate-900"><%= @pending_coupon_request_counts_by_classroom_id.fetch(classroom.id, 0) %></dd>
            </div>
            <div class="rounded-lg bg-slate-50 p-3">
              <dt class="text-slate-500">새 메시지</dt>
              <dd class="mt-1 text-lg font-bold text-slate-900"><%= @unread_student_message_counts_by_classroom_id.fetch(classroom.id, 0) %></dd>
            </div>
          </dl>
        </article>
      <% end %>
    </div>
  <% end %>
</section>
