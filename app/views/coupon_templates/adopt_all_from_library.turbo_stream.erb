<%= turbo_stream.update "personal" do %>
  <%= render partial: "personal_coupon_table_section", locals: { items: @personal_rows } %>
<% end %>
<% if defined?(@library) && @library.present? && current_user.admin? %>
  <%= turbo_stream.update "library" do %>
    <%= render partial: "library_coupon_table_section", locals: { templates: @library, library_admin: true } %>
  <% end %>
<% end %>
