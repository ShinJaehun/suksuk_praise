<section class="mx-auto w-full max-w-6xl space-y-6 pt-4 pb-8">
  <h1 class="text-2xl font-extrabold tracking-tight text-slate-900"><%= t("coupon_templates.index.title") %></h1>

  <section class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm">
    <%= turbo_frame_tag "personal", class: "block" do %>
      <%= render partial: "personal_coupon_table_section", locals: { items: @personal_rows } %>
    <% end %>
  </section>

  <section class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm">
    <%= turbo_frame_tag "library", class: "block" do %>
      <%= render partial: "library_coupon_table_section",
            locals: {
              templates: @library,
              library_admin: @library_admin,
              adopted_source_ids: @adopted_library_source_ids
            } %>
    <% end %>
  </section>
</section>
