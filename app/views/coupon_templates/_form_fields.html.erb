<%# locals: f, remove_image_template: nil %>

<% if f.object.errors.any? %>
  <div class="mb-3 rounded-lg border border-rose-200 bg-rose-50 px-3 py-2 text-sm text-rose-700">
    <%= f.object.errors.full_messages.to_sentence %>
  </div>
<% end %>

<div class="mb-3">
  <%= f.label :title, t("coupon_templates.form.title") %>
  <%= f.text_field :title, class: "w-full border p-2 rounded" %>
</div>

<% if f.object.bucket == "library" %>
  <div class="mb-3">
    <%= f.label :weight, t("coupon_templates.form.weight") %>
    <%= f.number_field :weight,
          in: 0..100,
          step: 10,
          class: "w-full border p-2 rounded" %>
  </div>

  <div class="mb-3 flex items-center gap-2">
    <%= f.check_box :active %>
    <%= f.label :active, t("coupon_templates.form.active"), class: "mb-0" %>
  </div>
<% end %>

<% initial_image_source = coupon_thumbnail_source(f.object) %>
<div class="mb-3"
     data-controller="coupon-image-preview"
     data-coupon-image-preview-initial-source-value="<%= initial_image_source %>">
  <%= f.label :image, t("coupon_templates.form.image") %>
  <div class="mb-3 flex items-end gap-3" data-coupon-image-preview-target="previewContainer">
    <%= tag.img src: initial_image_source,
          alt: t("coupon_templates.form.image_preview_alt"),
          class: "h-24 w-24 rounded-xl border border-slate-200 bg-white object-cover",
          data: { coupon_image_preview_target: "preview" } %>
    <% if local_assigns[:remove_image_template] %>
      <%= link_to t("coupon_templates.actions.remove_image"),
            remove_image_coupon_template_path(remove_image_template),
            data: {
              turbo_method: :delete,
              turbo_confirm: t("coupon_templates.confirm.remove_image")
            },
            class: "text-sm text-slate-500 underline hover:text-red-600" %>
    <% end %>
  </div>
  <%= f.file_field :image,
        accept: "image/jpeg,image/png,image/webp",
        class: "w-full border p-2 rounded",
        data: {
          coupon_image_preview_target: "input",
          action: "change->coupon-image-preview#update"
        } %>
</div>
