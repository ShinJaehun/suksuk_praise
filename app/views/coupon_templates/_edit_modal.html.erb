<div class="fixed inset-0 flex items-center justify-center bg-black/50 z-50" data-controller="modal">
  <div class="relative bg-white p-6 rounded shadow-lg w-full max-w-md">
    <button type="button" data-action="modal#clear"
            class="absolute top-2 right-3 text-gray-500 hover:text-gray-700">✕</button>

    <h1 class="text-xl font-bold mb-4">
      <%= t("coupon_templates.edit.title") %>
    </h1>

    <%= form_with model: @coupon_template do |f| %>
      <%= render partial: "form_fields",
            locals: {
              f: f,
              remove_image_template: (@coupon_template if @coupon_template.image_attachment&.persisted?)
            } %>
      <div class="mt-4 flex items-center justify-between">
        <div class="flex items-center gap-2">
          <%= f.submit t("ui.save"), class: "px-3 py-1 bg-blue-600 text-white rounded" %>
          <%= link_to t("ui.cancel"), "#",
                data: { action: "modal#clear" },
                class: "px-3 py-1 rounded border text-sm" %>
        </div>
        <span class="text-xs text-gray-400"> </span>
      </div>
    <% end %>

    <hr class="my-4">

    <div class="flex items-center justify-between">
      <div class="text-xs text-gray-500"><%= t("coupon_templates.edit.delete_warning") %></div>
      <%= button_to t("coupon_templates.actions.delete_coupon"),
            coupon_template_path(@coupon_template),
            method: :delete,
            form: {
              data: {
                turbo_confirm: t("coupon_templates.confirm.delete")
              }
            },
            class: "rounded-lg border border-red-200 bg-white px-3 py-2 text-sm font-semibold text-red-600 hover:bg-red-50" %>
    </div>
  </div>
</div>
