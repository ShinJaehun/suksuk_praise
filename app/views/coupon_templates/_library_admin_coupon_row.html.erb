<%# locals: tpl:, adopted_source_ids:, title_conflict_source_ids: [] %>
<% adopted = adopted_source_ids.include?(tpl.id) %>
<% title_conflict = local_assigns.fetch(:title_conflict_source_ids, []).include?(tpl.id) %>

<article id="<%= dom_id(tpl, :library_admin) %>" class="grid min-w-0 grid-cols-[minmax(0,1fr)_auto] items-center gap-x-3 gap-y-4 px-5 py-4 lg:grid-cols-[minmax(0,1fr)_auto_auto_auto] lg:gap-x-6">
  <%= render "coupon_templates/coupon_identity", tpl: tpl %>

  <%= render "coupon_templates/status_toggle",
        tpl: tpl,
        disabled: false,
        title: nil %>

  <div class="col-span-2 lg:col-span-1">
    <%= render "coupon_templates/weight_stepper",
          tpl: tpl,
          can_decrease: tpl.weight.to_i > 0,
          decrease_title: (tpl.weight.to_i <= 0 ? t("coupon_templates.titles.minimum_weight") : nil),
          can_increase: tpl.weight.to_i < 100,
          increase_title: (tpl.weight.to_i >= 100 ? t("coupon_templates.titles.maximum_weight") : nil) %>
  </div>

  <div class="col-span-2 flex flex-wrap items-center justify-end gap-2 lg:col-span-1">
    <% if adopted %>
      <span class="inline-flex min-h-9 items-center rounded-full bg-emerald-50 px-3 py-1.5 text-sm font-semibold text-emerald-700">
        <%= t("coupon_templates.status.added") %>
      </span>
    <% elsif title_conflict %>
      <span class="inline-flex min-h-9 items-center rounded-full bg-amber-50 px-3 py-1.5 text-sm font-semibold text-amber-700">
        <%= t("coupon_templates.status.title_conflict") %>
      </span>
    <% else %>
      <%= button_to t("coupon_templates.actions.adopt"),
            adopt_coupon_template_path(tpl),
            method: :post,
            form: { data: { controller: "disable-on-submit" } },
            class: "inline-flex min-h-9 items-center justify-center rounded-lg bg-blue-600 px-3 py-2 text-sm font-semibold text-white hover:bg-blue-700 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:ring-offset-2" %>
    <% end %>

    <%= link_to t("ui.edit"), edit_coupon_template_path(tpl),
            data: { turbo_frame: "modal" },
            class: "inline-flex min-h-9 items-center justify-center rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-50 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:ring-offset-2" %>
  </div>
</article>
