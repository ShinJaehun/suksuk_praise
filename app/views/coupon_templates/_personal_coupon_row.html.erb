<%# locals: row: %>
<% tpl = row.tpl %>

<article id="<%= dom_id(tpl) %>" class="grid min-w-0 grid-cols-[minmax(0,1fr)_auto] items-center gap-x-3 gap-y-4 px-5 py-4 lg:grid-cols-[minmax(0,1fr)_auto_auto_auto] lg:gap-x-6">
  <%= render "coupon_templates/coupon_identity", tpl: tpl %>

  <%= render "coupon_templates/status_toggle",
        tpl: tpl,
        disabled: !row.can_toggle_active,
        title: row.toggle_title %>

  <div class="col-span-2 lg:col-span-1">
    <%= render "coupon_templates/weight_stepper",
          tpl: tpl,
          can_decrease: row.can_decrease_weight,
          decrease_title: row.decrease_title,
          can_increase: row.can_increase_weight,
          increase_title: row.increase_title %>
  </div>

  <div class="col-span-2 flex justify-end lg:col-span-1">
    <%= link_to t("ui.edit"),
          edit_coupon_template_path(tpl),
          data: { turbo_frame: "modal" },
          class: "inline-flex min-h-9 items-center justify-center rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-50 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:ring-offset-2" %>
  </div>
</article>
