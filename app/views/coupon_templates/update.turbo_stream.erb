<%= turbo_stream.update "personal" do %>
  <%= render partial: "personal_coupon_table_section", locals: { items: @personal_rows } %>
<% end %>
<%# 라이브러리 갱신 데이터가 준비된 경우에만 갱신 %>
<% if defined?(@library) && @library.present? %>
  <%= turbo_stream.update "library" do %>
    <%= render partial: "library_coupon_table_section",
          locals: {
            templates: @library,
            library_admin: current_user.admin?,
            adopted_source_ids: @adopted_library_source_ids,
            title_conflict_source_ids: @library_title_conflict_ids
          } %>
  <% end %>
<% end %>
<%= turbo_stream.update "modal", "" %> <!-- modal 닫기 -->
