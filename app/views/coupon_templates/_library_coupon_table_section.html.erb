<%# locals: templates:, library_admin:, adopted_source_ids:, title_conflict_source_ids: [] %>
<header class="flex flex-col gap-3 border-b border-slate-200 px-5 py-4 sm:flex-row sm:items-center sm:justify-between">
  <h2 class="text-lg font-bold text-slate-900"><%= t("coupon_templates.tabs.library") %></h2>
  <div class="flex flex-wrap items-center gap-2">
    <% if library_admin %>
      <%= button_to t("coupon_templates.actions.rebalance_library"),
            rebalance_library_coupon_templates_path,
            method: :post,
            form: {
              class: "inline-block",
              data: {
                turbo_confirm: t("coupon_templates.confirm.rebalance_library")
              }
            },
            class: "inline-flex min-h-10 items-center justify-center rounded-lg border border-slate-300 bg-white px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-50 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:ring-offset-2" %>
      <%= link_to t("coupon_templates.actions.new_in_library"),
            new_coupon_template_path(bucket: "library"),
            data: { turbo_frame: "modal" },
            class: "inline-flex min-h-10 items-center justify-center rounded-lg bg-blue-600 px-4 py-2 text-sm font-semibold text-white hover:bg-blue-700 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:ring-offset-2" %>
    <% else %>
      <%= button_to t("coupon_templates.actions.adopt_all_from_library"),
            adopt_all_from_library_coupon_templates_path,
            method: :post,
            form: {
              class: "inline-block",
              data: {
                turbo_confirm: t("coupon_templates.confirm.adopt_all")
              }
            },
            class: "inline-flex min-h-10 items-center justify-center rounded-lg bg-blue-600 px-4 py-2 text-sm font-semibold text-white hover:bg-blue-700 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:ring-offset-2" %>
    <% end %>
  </div>
</header>

<% if library_admin %>
  <%= render partial: "library_admin_coupon_table", locals: { templates: templates } %>
<% else %>
  <%= render partial: "library_coupon_table",
        locals: {
          templates: templates,
          adopted_source_ids: adopted_source_ids,
          title_conflict_source_ids: local_assigns.fetch(:title_conflict_source_ids, [])
        } %>
<% end %>
