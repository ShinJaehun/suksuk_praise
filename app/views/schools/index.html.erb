<section class="mx-auto w-full max-w-6xl py-6">
  <div class="flex items-center justify-between gap-4">
    <h1 class="text-3xl font-extrabold tracking-tight text-slate-900"><%= t("schools.index.title") %></h1>
    <% if current_user.admin? %>
      <%= link_to t("classrooms.index.add_school"), new_admin_school_path, data: { turbo_frame: "modal" }, class: "rounded-lg bg-sky-600 px-4 py-2 text-sm font-semibold text-white hover:bg-sky-700" %>
    <% end %>
  </div>

  <div class="mt-6 grid gap-4 md:grid-cols-2">
    <% @schools.each do |school| %>
      <article class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
        <div class="flex items-start justify-between gap-3">
          <h2 class="text-xl font-bold text-slate-900"><%= school.name %></h2>
          <% if current_user.admin? %>
            <%= link_to t("ui.edit"), edit_admin_school_path(school), data: { turbo_frame: "modal" }, class: "text-sm font-semibold text-slate-600 hover:text-slate-900" %>
          <% end %>
        </div>
        <p class="mt-3 text-sm text-slate-600"><%= t("schools.index.summary", classrooms: @classroom_counts.fetch(school.id, 0), teachers: @teacher_counts.fetch(school.id, 0)) %></p>
        <p class="mt-1 text-sm text-slate-600"><%= t("schools.index.administrators", names: @managers_by_school_id.fetch(school.id, []).map { |membership| display_name(membership.user) }.presence&.join(", ") || t("schools.index.administrators_empty")) %></p>
        <%= link_to t("schools.index.open"), school_path(school), class: "mt-4 inline-flex rounded-lg border border-sky-300 bg-sky-50 px-3 py-2 text-sm font-semibold text-sky-700 hover:bg-sky-100" %>
      </article>
    <% end %>
  </div>
</section>
