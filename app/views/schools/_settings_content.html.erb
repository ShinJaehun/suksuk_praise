<h1 class="text-xl font-bold text-slate-900"><%= t("schools.settings.title") %></h1>

<section class="rounded-xl border border-slate-200 p-4">
  <h2 class="text-base font-bold text-slate-900"><%= t("schools.settings.name_title") %></h2>
  <%= form_with model: @school, class: "mt-3 space-y-3", data: { turbo_frame: "_top" } do |form| %>
    <div>
      <%= form.label :name, t("schools.settings.name_label"), class: "block text-sm font-semibold text-slate-800" %>
      <%= form.text_field :name, class: "mt-1 block w-full rounded-lg border border-slate-300 px-3 py-2 text-sm" %>
      <% if @school.errors[:name].any? %>
        <p class="mt-1 text-sm text-rose-600"><%= @school.errors.full_messages_for(:name).to_sentence %></p>
      <% end %>
    </div>
    <%= form.submit t("schools.settings.name_submit"),
          data: { turbo_submits_with: t("ui.processing") },
          class: "rounded-lg bg-sky-600 px-4 py-2 text-sm font-semibold text-white" %>
  <% end %>
</section>

<section class="rounded-xl border border-slate-200 p-4">
  <h2 class="text-base font-bold text-slate-900"><%= t("schools.settings.managers_title") %></h2>
  <div class="mt-3 space-y-2">
    <% if @managers.any? %>
      <% @managers.each do |membership| %>
        <div class="flex items-center justify-between gap-3">
          <span class="text-sm font-semibold text-slate-800"><%= display_name(membership.user) %></span>
          <%= link_to t("schools.settings.manager_remove"),
                admin_school_manager_path(@school, membership.user),
                data: { turbo_method: :delete, turbo_confirm: t("schools.settings.manager_remove_confirm") },
                class: "text-sm font-semibold text-rose-700" %>
        </div>
      <% end %>
    <% else %>
      <p class="text-sm text-slate-500"><%= t("schools.show.administrators_empty") %></p>
    <% end %>
  </div>

  <%= form_with url: admin_school_school_managers_path(@school), class: "mt-4 space-y-3" do |form| %>
    <div>
      <%= form.label :user_id, t("schools.settings.manager_candidate_label"), class: "block text-sm font-semibold text-slate-800" %>
      <%= form.collection_select :user_id,
            @manager_candidates,
            :id,
            :name,
            { prompt: t("schools.settings.manager_prompt") },
            { class: "mt-1 block w-full rounded-lg border border-slate-300 px-3 py-2 text-sm" } %>
    </div>
    <%= form.submit t("schools.settings.manager_assign"),
          data: { turbo_submits_with: t("ui.processing") },
          class: "rounded-lg bg-sky-600 px-4 py-2 text-sm font-semibold text-white" %>
  <% end %>
</section>
