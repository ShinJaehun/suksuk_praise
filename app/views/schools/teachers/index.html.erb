<section class="mx-auto w-full max-w-6xl pt-4">
  <div class="mb-6 flex flex-col items-start justify-between gap-3 sm:flex-row sm:items-center">
    <div>
      <p class="text-sm font-semibold text-sky-700"><%= @school.name %></p>
      <h1 class="mt-1 text-2xl font-extrabold tracking-tight text-slate-900"><%= t("schools.teachers.index.title") %></h1>
      <p class="mt-1 text-sm text-slate-500"><%= t("schools.teachers.index.description") %></p>
    </div>
    <%= link_to t("schools.teachers.index.add_teacher"),
          new_school_teacher_path(@school),
          data: { turbo_frame: "modal" },
          class: "inline-flex w-full items-center justify-center rounded-lg bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow hover:bg-emerald-700 sm:w-auto" %>
  </div>

  <section class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm">
    <div class="border-b border-slate-200 px-5 py-4">
      <h2 class="text-lg font-bold text-slate-900"><%= t("schools.teachers.index.list_title") %></h2>
    </div>

    <% if @teacher_rows.any? %>
      <div class="divide-y divide-slate-200">
        <% @teacher_rows.each do |row| %>
          <% teacher = row[:teacher] %>
          <% classroom_names = row[:classroom_names] %>
          <% visible_classroom_names = classroom_names.first(3) %>

          <article class="grid gap-4 px-5 py-4 lg:grid-cols-[minmax(12rem,1.2fr)_minmax(8rem,0.7fr)_minmax(14rem,1.4fr)_auto] lg:items-center">
            <div class="flex min-w-0 items-center gap-3">
              <%= user_avatar_image(
                    teacher,
                    size: 128,
                    class: "h-10 w-10 shrink-0 rounded-xl border border-slate-200 bg-slate-100 object-cover",
                    alt: "#{display_name(teacher)} avatar"
                  ) %>
              <div class="min-w-0">
                <p class="truncate text-sm font-semibold text-slate-900"><%= display_name(teacher) %></p>
                <p class="truncate text-xs text-slate-500"><%= teacher.email %></p>
              </div>
            </div>

            <div>
              <p class="text-xs font-semibold text-slate-500"><%= t("schools.teachers.index.school_role") %></p>
              <p class="mt-1 text-sm text-slate-800"><%= row[:school_role_label] %></p>
            </div>

            <div class="min-w-0">
              <p class="text-xs font-semibold text-slate-500"><%= t("schools.teachers.index.classrooms") %></p>
              <p class="mt-1 truncate text-sm text-slate-800">
                <% if classroom_names.any? %>
                  <%= visible_classroom_names.join(", ") %>
                  <% if classroom_names.size > visible_classroom_names.size %>
                    <%= t("classrooms.index.additional_classrooms", count: classroom_names.size - visible_classroom_names.size) %>
                  <% end %>
                <% else %>
                  <%= t("schools.teachers.index.unassigned_classroom") %>
                <% end %>
              </p>
              <p class="mt-0.5 text-xs text-slate-500">
                <%= t("classrooms.index.assigned_count", count: row[:classroom_count]) %> · <%= row[:grade_label] %>
              </p>
            </div>

            <div class="flex justify-start lg:justify-end">
              <%= link_to t("ui.edit"),
                    edit_school_teacher_path(@school, teacher),
                    data: { turbo_frame: "modal" },
                    class: "inline-flex rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-50" %>
            </div>
          </article>
        <% end %>
      </div>
    <% else %>
      <div class="px-5 py-10 text-center">
        <p class="text-sm text-slate-500"><%= t("schools.teachers.index.empty") %></p>
        <%= link_to t("schools.teachers.index.add_teacher"),
              new_school_teacher_path(@school),
              data: { turbo_frame: "modal" },
              class: "mt-4 inline-flex rounded-lg border border-emerald-300 bg-emerald-50 px-4 py-2 text-sm font-semibold text-emerald-700 hover:bg-emerald-100" %>
      </div>
    <% end %>
  </section>
</section>
