<section class="mx-auto w-full max-w-3xl space-y-6 pt-4">
  <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <h1 class="text-2xl font-extrabold tracking-tight text-slate-900"><%= @user.name %> 계정 관리</h1>
      </div>

      <%= link_to "#{@user.name} 페이지로 돌아가기",
            classroom_student_path(@classroom, @user),
            class: "inline-flex items-center rounded-lg border border-slate-300 bg-white px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-50" %>
    </div>
  </div>

  <% if @user.errors.any? %>
    <div role="alert"
         class="rounded-2xl border border-rose-200 bg-rose-50 px-5 py-4 text-sm font-medium text-rose-700 shadow-sm">
      <%= @user.errors.full_messages.to_sentence %>
    </div>
  <% end %>

  <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
    <h2 class="text-base font-semibold text-slate-900">기본 정보</h2>

    <%= simple_form_for @user, url: classroom_student_path(@classroom, @user), method: :patch do |f| %>
      <div class="mt-4 space-y-5">
        <div class="flex flex-col gap-4 sm:flex-row sm:items-center">
          <button type="button"
                  class="group w-fit"
                  onclick="document.getElementById('student-avatar-dialog').showModal()">
            <%= user_avatar_image(@user,
                  size: 128,
                  class: "h-24 w-24 rounded-2xl border border-slate-200 bg-slate-100 object-cover transition group-hover:border-blue-400",
                  alt: "#{@user.name} avatar") %>
          </button>

          <button type="button"
                  class="inline-flex w-fit items-center justify-center rounded-lg border border-slate-300 bg-white px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-50"
                  onclick="document.getElementById('student-avatar-dialog').showModal()">
            아바타 변경
          </button>
        </div>

        <div class="grid gap-5 md:grid-cols-2">
          <%= f.input :name,
                required: true,
                input_html: {
                  class: "block w-full rounded-xl border border-slate-300 px-4 py-3 text-sm text-slate-900 shadow-sm placeholder:text-slate-400 focus:border-sky-500 focus:outline-none focus:ring-2 focus:ring-sky-100"
                },
                label_html: { class: "mb-2 block text-sm font-medium text-slate-700" } %>

          <%= f.input :gender,
                collection: [["남학생", "boy"], ["여학생", "girl"]],
                include_blank: "선택해 주세요",
                label: "성별",
                input_html: {
                  class: "block w-full rounded-xl border border-slate-300 px-4 py-3 text-sm text-slate-900 shadow-sm focus:border-sky-500 focus:outline-none focus:ring-2 focus:ring-sky-100"
                },
                label_html: { class: "mb-2 block text-sm font-medium text-slate-700" } %>
        </div>

        <dialog id="student-avatar-dialog" 
          class="fixed inset-0 m-auto w-[min(42rem,calc(100vw-2rem))] max-h-[calc(100vh-2rem)] overflow-hidden rounded-2xl border border-slate-200 bg-white p-0 shadow-xl backdrop:bg-black/50">
          <div class="p-5">
            <div class="flex items-center justify-between gap-3">
              <h3 class="text-base font-semibold text-slate-900">아바타 선택</h3>
            </div>

            <div class="mt-4 grid max-h-[60vh] grid-cols-4 gap-3 overflow-y-auto sm:grid-cols-6 md:grid-cols-8">
              <% @student_avatar_keys.each do |avatar_key| %>
                <label class="flex cursor-pointer flex-col items-center gap-2 rounded-xl border border-slate-200 p-2 text-xs text-slate-600 has-[:checked]:border-blue-500 has-[:checked]:bg-blue-50">
                  <%= f.radio_button :avatar_key, avatar_key, class: "sr-only" %>
                  <%= image_tag "avatars/#{avatar_key}.png",
                        class: "h-12 w-12 rounded-xl object-cover",
                        alt: avatar_key %>
                </label>
              <% end %>
            </div>

            <div class="mt-5 flex justify-end gap-2 border-t border-slate-100 pt-4">
              <button type="button"
                      class="inline-flex items-center justify-center rounded-lg border border-slate-300 bg-white px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-50"
                      onclick="document.getElementById('student-avatar-dialog').close()">
                닫기
              </button>
              <%= f.button :submit,
                    "저장하기",
                    class: "inline-flex items-center justify-center rounded-lg bg-blue-600 px-4 py-2 text-sm font-semibold text-white hover:bg-blue-700" %>
            </div>            
          </div>
        </dialog>

        <div class="flex justify-end">
          <%= f.button :submit,
                "저장하기",
                class: "inline-flex items-center justify-center rounded-lg bg-blue-600 px-4 py-2 text-sm font-semibold text-white hover:bg-blue-700" %>
        </div>
      </div>
    <% end %>
  </div>

  <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
    <h2 class="text-base font-semibold text-slate-900">PIN 설정</h2>

    <%= simple_form_for @user, url: classroom_student_path(@classroom, @user), method: :patch do |f| %>
      <div class="mt-4 space-y-5">
        <div>
          <%= f.label :student_pin, "새 PIN (4자리)", class: "mb-2 block text-sm font-medium text-slate-700" %>
          <p class="mb-2 text-sm font-medium text-slate-600">
            현재 PIN:
            <% if @user.default_student_pin? %>
              기본 PIN(1234)으로 설정됨
            <% elsif @user.student_pin_configured? %>
              설정됨
            <% else %>
              미설정
            <% end %>
          </p>
          <%= f.password_field :student_pin,
                value: nil,
                maxlength: 4,
                inputmode: "numeric",
                pattern: "\\d{4}",
                autocomplete: "one-time-code",
                class: "block w-full rounded-xl border border-slate-300 px-4 py-3 text-sm text-slate-900 shadow-sm placeholder:text-slate-400 focus:border-sky-500 focus:outline-none focus:ring-2 focus:ring-sky-100" %>
          <p class="mt-1 text-sm text-slate-500">새 PIN을 입력하면 변경됩니다. 비워두면 기존 PIN을 유지합니다.</p>
        </div>

        <div class="flex justify-end">
          <%= f.button :submit,
                "저장하기",
                class: "inline-flex items-center justify-center rounded-lg bg-blue-600 px-4 py-2 text-sm font-semibold text-white hover:bg-blue-700" %>
        </div>
      </div>
    <% end %>
  </div>

  <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
    <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
      <div>
        <h2 class="text-base font-semibold text-slate-900"><%= t("students.membership.title") %></h2>
      </div>

      <% if @student_membership.inactive? %>
        <span class="w-fit rounded-full bg-slate-100 px-2 py-0.5 text-xs font-semibold text-slate-600">
          <%= t("ui.inactive") %>
        </span>
      <% end %>
    </div>

    <% if @student_membership.active? %>
      <%= button_to t("students.actions.deactivate"),
            deactivate_classroom_student_path(@classroom, @user),
            method: :patch,
            data: { turbo_confirm: t("students.deactivate.confirm") },
            class: "mt-4 inline-flex items-center justify-center rounded-lg border border-rose-300 bg-white px-4 py-2 text-sm font-semibold text-rose-700 hover:bg-rose-50" %>
    <% else %>
      <%= button_to t("students.actions.reactivate"),
            reactivate_classroom_student_path(@classroom, @user),
            method: :patch,
            class: "mt-4 inline-flex items-center justify-center rounded-lg border border-emerald-300 bg-white px-4 py-2 text-sm font-semibold text-emerald-700 hover:bg-emerald-50" %>
    <% end %>
  </div>
</section>
