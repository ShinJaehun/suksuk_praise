<section class="mx-auto w-full max-w-3xl space-y-6 pt-4">
  <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <h1 class="text-2xl font-extrabold tracking-tight text-slate-900"><%= @user.name %> 계정 관리</h1>
      </div>

      <%= link_to "#{@user.name} 페이지로 돌아가기",
            classroom_student_path(@classroom, @user),
            class: "inline-flex items-center rounded-lg border border-slate-300 bg-white px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-50" %>
    </div>
  </div>

  <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
    <h2 class="text-base font-semibold text-slate-900">기본 정보 수정</h2>

    <%= simple_form_for @user, url: classroom_student_path(@classroom, @user), method: :patch do |f| %>
      <div class="mt-4 space-y-5">
        <div class="grid gap-5 md:grid-cols-2">
          <%= f.input :name,
                required: true,
                input_html: {
                  class: "block w-full rounded-xl border border-slate-300 px-4 py-3 text-sm text-slate-900 shadow-sm placeholder:text-slate-400 focus:border-sky-500 focus:outline-none focus:ring-2 focus:ring-sky-100"
                },
                label_html: { class: "mb-2 block text-sm font-medium text-slate-700" } %>

          <%= f.input :email,
                required: true,
                input_html: {
                  class: "block w-full rounded-xl border border-slate-300 px-4 py-3 text-sm text-slate-900 shadow-sm placeholder:text-slate-400 focus:border-sky-500 focus:outline-none focus:ring-2 focus:ring-sky-100"
                },
                label_html: { class: "mb-2 block text-sm font-medium text-slate-700" } %>
        </div>

        <div class="flex justify-end">
          <%= f.button :submit,
                "저장하기",
                class: "inline-flex items-center justify-center rounded-lg bg-blue-600 px-4 py-2 text-sm font-semibold text-white hover:bg-blue-700" %>
        </div>
      </div>
    <% end %>
  </div>

  <div class="rounded-2xl border border-amber-200 bg-amber-50 p-5 shadow-sm">
    <h2 class="text-base font-semibold text-amber-900">비밀번호 재설정</h2>
    <p class="mt-1 text-sm text-amber-800">새 임시 비밀번호를 직접 설정합니다.</p>

    <%= simple_form_for @user, url: reset_password_classroom_student_path(@classroom, @user), method: :patch do |f| %>
      <div class="mt-4 space-y-5">
        <div class="grid gap-5 md:grid-cols-2">
          <%= f.input :password,
                required: true,
                input_html: {
                  autocomplete: "new-password",
                  class: "block w-full rounded-xl border border-amber-300 px-4 py-3 text-sm text-slate-900 shadow-sm placeholder:text-slate-400 focus:border-amber-500 focus:outline-none focus:ring-2 focus:ring-amber-100"
                },
                label_html: { class: "mb-2 block text-sm font-medium text-amber-900" } %>

          <%= f.input :password_confirmation,
                required: true,
                input_html: {
                  autocomplete: "new-password",
                  class: "block w-full rounded-xl border border-amber-300 px-4 py-3 text-sm text-slate-900 shadow-sm placeholder:text-slate-400 focus:border-amber-500 focus:outline-none focus:ring-2 focus:ring-amber-100"
                },
                label_html: { class: "mb-2 block text-sm font-medium text-amber-900" } %>
        </div>

        <div class="flex justify-end">
          <%= f.button :submit,
                "비밀번호 재설정",
                class: "inline-flex items-center justify-center rounded-lg bg-amber-500 px-4 py-2 text-sm font-semibold text-white hover:bg-amber-600" %>
        </div>
      </div>
    <% end %>
  </div>

  <div class="rounded-2xl border border-rose-200 bg-rose-50 p-5 shadow-sm">
    <h2 class="text-base font-semibold text-rose-900">계정 삭제</h2>
    <p class="mt-1 text-sm text-rose-700">
      계정을 삭제하면 소속 정보와 관련 데이터가 함께 삭제될 수 있습니다. 이 작업은 되돌릴 수 없습니다.
    </p>

    <%= button_to "계정 삭제",
          classroom_student_path(@classroom, @user),
          method: :delete,
          data: { turbo_confirm: "정말로 이 학생 계정을 삭제하시겠습니까?" },
          class: "mt-4 inline-flex items-center justify-center rounded-lg border border-rose-300 bg-white px-4 py-2 text-sm font-semibold text-rose-700 hover:bg-rose-100" %>
  </div>
</section>
