<section class="mx-auto w-full max-w-6xl space-y-4 pt-4">
  <%= render "classroom_students/student_profile_card",
        classroom: @classroom,
        user: @user,
        kpi_counts: @kpi_counts,
        current_section: :activity,
        student_messages_enabled: @student_messages_enabled,
        can_manage_student: @can_manage_student,
        can_create_compliment: @can_create_compliment,
        can_draw_coupon: @can_draw_coupon %>

  <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
    <section class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
      <h2 class="text-base font-semibold text-slate-900"><%= t("students.show.activity.recent_coupons") %></h2>
      <div class="mt-3 max-h-[28rem] overflow-y-auto">
        <%= turbo_frame_tag dom_id(@user, :recent_issued_coupons) do %>
          <%= render partial: "user_coupons/issued_coupons",
            locals: { coupons: @recent_issued_coupons, show_user: false } %>
        <% end %>
      </div>
    </section>

    <section class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
      <h2 class="text-base font-semibold text-slate-900"><%= t("students.show.activity.compliments") %></h2>
      <div class="mt-3 max-h-[28rem] overflow-y-auto">
        <%= turbo_frame_tag dom_id(@user, :compliments) do %>
          <%= render partial: "users/compliments_timeline", locals: { compliments: @compliments } %>
        <% end %>
      </div>
    </section>
  </div>
</section>
