<%# locals: (classroom:, user:, available_coupon_templates:) %>
<%= turbo_frame_tag dom_id(user, :coupon_assignment) do %>
  <section class="rounded-2xl border border-blue-200 bg-white p-5 shadow-sm">
    <h2 class="text-base font-semibold text-slate-900"><%= t("students.show.coupon_assignment.title") %></h2>

    <% if available_coupon_templates.any? %>
      <div class="mt-4 grid gap-4 md:grid-cols-2">
        <div class="rounded-xl border border-slate-200 bg-slate-50 p-4">
          <h3 class="text-sm font-semibold text-slate-900"><%= t("students.show.coupon_assignment.random_title") %></h3>
          <p class="mt-1 text-sm text-slate-500"><%= t("students.show.coupon_assignment.random_description") %></p>
          <%= button_to t("ui.buttons.draw_random_coupon"),
                draw_coupon_classroom_path(
                  classroom,
                  basis: "manual",
                  mode: "default",
                  user_id: user.id
                ),
                method: :post,
                form: {
                  class: "mt-3",
                  data: {
                    controller: "disable-on-submit",
                    action: "turbo:submit-start->disable-on-submit#onSubmit turbo:submit-end->disable-on-submit#onTurboSubmitEnd",
                    turbo_submits_with: t("ui.processing")
                  },
                  aria: { busy: "false" }
                },
                class: "inline-flex items-center rounded-lg border border-blue-600 bg-blue-600 px-3 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-blue-700" %>
        </div>

        <div class="rounded-xl border border-slate-200 bg-slate-50 p-4">
          <h3 class="text-sm font-semibold text-slate-900"><%= t("students.show.coupon_assignment.selected_title") %></h3>
          <%= form_with url: classroom_student_coupons_path(classroom, user),
                method: :post,
                class: "mt-3 flex flex-col gap-3 sm:flex-row sm:items-end" do |form| %>
            <div class="min-w-0 flex-1">
              <%= form.label :coupon_template_id,
                    t("students.show.coupon_assignment.template_label"),
                    class: "block text-sm font-medium text-slate-700" %>
              <%= form.select :coupon_template_id,
                    options_from_collection_for_select(available_coupon_templates, :id, :title),
                    {},
                    class: "mt-1 block w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm shadow-sm focus:border-blue-500 focus:ring-blue-500" %>
            </div>
            <%= form.submit t("ui.buttons.assign_selected_coupon"),
                  class: "inline-flex cursor-pointer items-center justify-center rounded-lg border border-emerald-600 bg-emerald-600 px-3 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-emerald-700" %>
          <% end %>
        </div>
      </div>
    <% else %>
      <p class="mt-3 rounded-xl border border-dashed border-slate-300 bg-slate-50 px-4 py-5 text-sm text-slate-600">
        <%= t("students.show.coupon_assignment.empty") %>
      </p>
    <% end %>
  </section>
<% end %>
