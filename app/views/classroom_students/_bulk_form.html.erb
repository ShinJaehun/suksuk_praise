<%= turbo_frame_tag :modal do %>
  <!-- 오버레이 -->
  <div class="fixed inset-0 bg-black/50 flex items-center justify-center z-50" 
    data-controller="modal"
    role="dialog" aria-modal="true">
   
    <!-- 모달 컨테이너 -->
    <div class="bg-white rounded-lg shadow-lg w-full max-w-md p-8 relative">
      <h2 class="text-xl font-bold mb-4">여러 명 학생 자동생성</h2>
      <%= form_with url: bulk_create_classroom_students_path(classroom),
          method: :post,
          data: { turbo_frame: :modal, 
            action: "submit->modal#showProgress",
            turbo_submits_with: "처리중..." } do |f| %>
        <div class="mb-4 grid grid-cols-2 gap-3">
          <div>
            <%= f.label :boy_count, "남학생 수" %>
            <%= f.number_field :boy_count, value: 15, min: 0, max: 30, class: "border px-2 py-1 rounded w-full" %>
          </div>
          <div>
            <%= f.label :girl_count, "여학생 수" %>
            <%= f.number_field :girl_count, value: 15, min: 0, max: 30, class: "border px-2 py-1 rounded w-full" %>
          </div>
        </div>
        <div class="mb-4 text-sm text-slate-500">
          <p>한 번에 최대 30명까지 생성할 수 있어요.</p>
          <p>남학생 수와 여학생 수를 합한 인원 기준입니다.</p>
        </div>
        <div class="mb-4">
          <%= f.label :student_pin, "공통 초기 PIN (선택, 4자리)" %>
          <%= f.password_field :student_pin,
            maxlength: 4,
            inputmode: "numeric",
            pattern: "\\d{4}",
            class: "border px-2 py-1 rounded w-full" %>
        </div>
        <!-- progressbar : hidden -->
        <div data-modal-target="progress" class="hidden w-full mt-4">
          <div class="w-full bg-gray-200 h-2 rounded">
            <div class="bg-blue-500 h-2 rounded bar transition-all" style="width: 70%"></div>
          </div>
          <div class="text-xs mt-2 text-center">학생을 생성 중입니다...</div>
        </div>
        <div class="flex gap-2">
          <%= f.submit t('ui.buttons.bulk_create_students'),
            class: "bg-blue-500 text-white px-4 py-2 rounded" %>
          <button type="button" data-action="modal#close" class="bg-gray-300 px-4 py-2 rounded">닫기</button>
        </div>
      <% end %>
      <!-- 닫기(X) 아이콘 -->
      <button type="button" data-action="modal#close" class="absolute top-2 right-2 text-gray-400 hover:text-gray-600 text-2xl">&times;</button>
    </div>
  </div>
<% end %>
