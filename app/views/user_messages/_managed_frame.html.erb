<%= turbo_frame_tag dom_id, class: "block scroll-mt-24" do %>
  <section class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
    <%= render "user_messages/managed_section",
          threads: threads,
          message: message,
          reply_message: reply_message,
          user: user,
          form_url: form_url,
          can_write_messages: local_assigns.fetch(:can_write_messages, true),
          active_reply_thread_id: local_assigns[:active_reply_thread_id] %>
  </section>
<% end %>
