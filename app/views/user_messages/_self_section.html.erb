<% if teacher_options.any? %>
  <%= render "user_messages/message_form",
        message: new_message,
        form_url: user_messages_path(user),
        sender: current_user %>
<% end %>

<%= render "user_messages/thread",
      threads: threads,
      reply_message: reply_message,
      user: user,
      active_reply_thread_id: active_reply_thread_id %>
