<article class="rounded-2xl border border-slate-200 bg-white px-4 py-4 shadow-sm">
  <div class="flex items-start gap-3">
    <%= user_avatar_image(
          thread.sender,
          size: 128,
          class: "h-8 w-8 shrink-0 rounded-full border border-slate-200 bg-white object-cover",
          alt: "#{thread.sender.name} avatar"
        ) %>
    <div class="min-w-0 flex-1">
      <div class="flex flex-wrap items-baseline gap-x-2 gap-y-1">
        <p class="text-sm font-semibold text-slate-900"><%= thread.sender.name %></p>
        <p class="text-xs text-slate-500"><%= l(thread.created_at, format: :short) %></p>
      </div>
      <p class="mt-1 whitespace-pre-wrap break-words text-sm leading-6 text-slate-700"><%= thread.body %></p>
    </div>
  </div>

  <% if thread.replies.any? %>
    <div class="mt-4 space-y-3 border-t border-slate-200 pt-4">
      <% thread.replies.each do |reply| %>
        <%= render "user_messages/reply", reply: reply %>
      <% end %>
    </div>
  <% end %>

  <% if local_assigns.fetch(:can_write_messages, true) && show_user_message_reply_form?(thread, user) %>
    <div class="mt-4 border-t border-slate-200 pt-4">
      <%= render "user_messages/reply_form",
            thread: thread,
            reply_message: reply_message,
            form_url: local_assigns[:form_url],
            user: user,
            active: active_reply_thread_id == thread.id %>
    </div>
  <% end %>
</article>
