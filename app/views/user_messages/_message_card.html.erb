<article class="rounded-2xl border border-slate-200 bg-white px-4 py-4 shadow-sm">
  <div class="flex items-start justify-between gap-3">
    <div class="flex items-center gap-3">
      <%= user_avatar_image(
            thread.sender,
            size: 128,
            class: "h-8 w-8 rounded-full border border-slate-200 bg-white object-cover",
            alt: "#{thread.sender.name} avatar"
          ) %>
      <div class="flex flex-wrap items-center gap-2">
        <p class="text-sm font-semibold text-slate-900"><%= thread.sender.name %></p>
        <span class="rounded-full bg-slate-100 px-2 py-0.5 text-xs font-medium text-slate-600">
          <%= user_message_sender_label(thread) %>
        </span>
      </div>
    </div>
    <p class="shrink-0 text-xs text-slate-500"><%= l(thread.created_at, format: :short) %></p>
  </div>

  <p class="mt-3 whitespace-pre-wrap text-sm leading-6 text-slate-700"><%= thread.body %></p>

  <% if show_user_message_reply_form?(thread, user) %>
    <div class="mt-4 border-t border-slate-200 pt-4">
      <%= render "user_messages/reply_form",
            thread: thread,
            reply_message: reply_message,
            user: user,
            active: active_reply_thread_id == thread.id %>
    </div>
  <% end %>

  <% if thread.replies.any? %>
    <div class="mt-4 space-y-3 border-t border-slate-200 pt-4">
      <% thread.replies.each do |reply| %>
        <%= render "user_messages/reply", reply: reply %>
      <% end %>
    </div>
  <% end %>
</article>
