<%= simple_form_for message, url: form_url do |f| %>
  <%= f.hidden_field :recipient_id, value: recipient.id if local_assigns[:recipient].present? %>
  <%= hidden_field_tag :reply_to_message_id, reply_to_message_id if local_assigns[:reply_to_message_id].present? %>

  <div class="space-y-2 rounded-2xl bg-slate-50 p-3">
    <% if local_assigns.fetch(:show_errors, true) && message.errors.any? %>
      <div class="rounded-xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-700">
        <%= message.errors.full_messages.to_sentence %>
      </div>
    <% end %>

    <div class="flex flex-col gap-3 sm:flex-row sm:items-center">
      <div class="flex min-w-0 shrink-0 items-center gap-2 sm:w-44">
        <%= user_avatar_image(
              sender,
              size: 128,
              class: "h-8 w-8 rounded-full border border-slate-200 bg-white object-cover",
              alt: "#{sender.name} avatar"
            ) %>
        <p class="truncate text-sm font-semibold text-slate-900"><%= sender.name.presence || sender.email %></p>
      </div>

      <div class="min-w-0 flex-1">
        <%= f.input :body,
              as: :text,
              required: true,
              label: false,
              input_html: {
                rows: local_assigns.fetch(:rows, 1),
                class: "block w-full rounded-xl border px-3 py-2 text-sm text-slate-900 shadow-sm placeholder:text-slate-400 focus:outline-none focus:ring-2 #{message.errors.any? ? 'border-rose-300 focus:border-rose-400 focus:ring-rose-100' : 'border-slate-300 focus:border-sky-500 focus:ring-sky-100'}"
              } %>
      </div>

      <%= button_tag "보내기",
            type: :submit,
            class: "inline-flex h-10 w-full shrink-0 items-center justify-center rounded-xl border border-slate-200 bg-slate-100 px-4 text-sm font-semibold text-slate-700 transition hover:border-slate-300 hover:bg-slate-200 sm:w-auto" %>
    </div>
  </div>
<% end %>
