<section class="mx-auto w-full max-w-md pt-8">
  <div class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm">

    <%= image_tag "suksuk_logo.png",
          alt: "쑥쑥칭찬통장",
          class: "mx-auto h-auto w-20" %>
    <h1 class="mt-3 text-center text-2xl font-extrabold text-slate-900">쑥쑥칭찬통장</h1>
    
    <p class="mt-2 text-center text-sm text-slate-600">
      교사/관리자 로그인
    </p>

    <%= simple_form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "mt-6 space-y-4" }) do |f| %>
      <%= f.input :email,
            required: false,
            autofocus: true,
            label: "이메일",
            input_html: {
              autocomplete: "email",
              class: "block w-full rounded-lg border border-slate-300 px-3 py-2 text-sm"
            } %>

      <%= f.input :password,
            required: false,
            label: "비밀번호",
            input_html: {
              autocomplete: "current-password",
              class: "block w-full rounded-lg border border-slate-300 px-3 py-2 text-sm"
            } %>

      <%= f.input :remember_me,
            as: :boolean,
            label: "로그인 상태 유지" if devise_mapping.rememberable? %>

      <%= f.button :submit,
            "로그인",
            class: "w-full rounded-lg bg-emerald-600 px-4 py-2 text-sm font-semibold text-white hover:bg-emerald-700" %>
    <% end %>

    <div class="mt-5 border-t border-slate-100 pt-4 text-sm">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</section>
