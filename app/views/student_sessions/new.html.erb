<section class="mx-auto w-full max-w-md pt-8">
  <div class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm">
    <h1 class="text-xl font-bold text-slate-900">학생 PIN 로그인</h1>

    <% if @classroom %>
      <p class="mt-2 text-sm text-slate-600"><%= @classroom.name %></p>

      <%= form_with url: @student_session_form_url,
            method: :post,
            class: "mt-6 space-y-4",
            data: { controller: "student-login-preview" } do %>
        <div>
          <%= label_tag :student_id, "로그인할 학생을 선택하세요", class: "mb-1 block text-sm font-medium text-slate-700" %>
          <%= select_tag :student_id,
                options_for_select(
                  @students.map do |student|
                    [
                      student.name,
                      student.id,
                      {
                        data: {
                          avatar_url: image_path(user_avatar_path(student, size: 128)),
                          student_name: student.name
                        }
                      }
                    ]
                  end,
                  params[:student_id]
                ),
                prompt: "선택하세요",
                data: {
                  student_login_preview_target: "select",
                  action: "student-login-preview#update"
                },
                class: "block w-full rounded-lg border border-slate-300 px-3 py-2 text-sm" %>
        </div>

        <div class="mx-auto w-fit rounded-lg border border-slate-200 bg-slate-50 px-5 py-4 text-center">
          <div class="flex flex-col items-center">
            <%= image_tag "suksuk_logo.png",
                  alt: "쑥쑥칭찬통장",
                  data: { student_login_preview_target: "image" },
                  class: "h-16 w-16 rounded-xl object-contain opacity-70" %>
            <p data-student-login-preview-target="name" class="mt-3 text-sm font-semibold text-slate-800">
            </p>
          </div>
        </div>

        <div>
          <%= label_tag :student_pin, "PIN을 입력하세요", class: "mb-1 block text-sm font-medium text-slate-700" %>
          <%= password_field_tag :student_pin,
                nil,
                maxlength: 4,
                inputmode: "numeric",
                pattern: "\\d{4}",
                autocomplete: "one-time-code",
                class: "block w-full rounded-lg border border-slate-300 px-3 py-2 text-sm" %>
        </div>

        <%= submit_tag "로그인",
              class: "w-full rounded-lg bg-blue-600 px-4 py-2 text-sm font-semibold text-white hover:bg-blue-700" %>
      <% end %>
    <% else %>
      <p class="mt-4 text-sm text-slate-600">
        학생 로그인은 교실별 로그인 주소를 사용해 주세요.
      </p>
    <% end %>
  </div>
</section>
