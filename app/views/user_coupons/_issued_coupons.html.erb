<%# locals: (coupons:, show_user:) %>
<% if coupons&.any? %>
  <ul class="space-y-2">
    <% coupons.each do |coupon| %>
      <li id="<%= dom_id(coupon, :recent) %>" class="flex flex-wrap items-center gap-2 rounded-lg border border-slate-200 bg-slate-50 px-3 py-2 text-sm">
        <% if show_user %>
          <span class="font-semibold text-slate-800"><%= coupon.user.name %></span>
          <span class="text-slate-400">→</span>
        <% end %>

        <span class="font-semibold text-slate-900"><%= coupon.coupon_template.title %></span>

        <%= coupon_basis_badge(coupon) %>
        <% if (period_tag = coupon_period_tag(coupon)) %>
          <%= period_tag %>
        <% end %>
        <% if coupon.status == "used" %>
          <span class="inline-block rounded-full bg-slate-900 px-2 py-0.5 text-[11px] font-bold text-white shadow-sm">
            사용함
          </span>
        <% end %>

        <span class="text-slate-500">(<%= l coupon.issued_at, format: :short %>)</span>
      </li>
    <% end %>
  </ul>
<% else %>
  <p class="rounded-lg border border-dashed border-slate-300 bg-slate-50 px-3 py-4 text-sm text-slate-500"><%= t("empty.issued_coupons") %></p>
<% end %>
