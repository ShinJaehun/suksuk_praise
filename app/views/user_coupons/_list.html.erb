<%# locals: (coupons:, user:, pending_coupon_use_requests_by_coupon_id: {}) %>
<% if coupons.present? %>

  <ul class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-3">
    <% coupons.each do |c| %>
      <li id="<%= dom_id(c) %>" class="flex flex-col items-stretch gap-3 rounded border px-3 py-2 sm:flex-row sm:items-center sm:justify-between">
        <div class="flex min-w-0 items-center gap-3">
          <div>
            <% tpl = c.coupon_template %>
            <% if tpl.image.attached? %>
              <%= image_tag(tpl.image, class: "h-14 w-14 rounded object-cover shrink-0") %>
            <% elsif tpl.default_image_key.present? %>
              <%= image_tag(tpl.default_image_key, class: "h-14 w-14 rounded object-cover shrink-0") %>
            <% else %>
              <div class="h-14 w-14 rounded bg-slate-100 shrink-0"></div>
            <% end %>
          </div>

          <div class="min-w-0">
            <div class="font-semibold truncate"><%= c.coupon_template.title %></div>

            <div class="mt-1 flex items-center gap-1">
              <%= coupon_basis_badge(c) %>
              <% if (period_tag = coupon_period_tag(c)) %>
                <%= period_tag %>
              <% end %>
            </div>

            <div class="mt-2 text-xs text-gray-500">
              발급: <%= l(c.issued_at, format: :short) %> · 교실 #<%= c.classroom_id %>
            </div>
          </div>
        </div>

        <div class="shrink-0 w-full sm:w-auto">
          <% pending_request = pending_coupon_use_requests_by_coupon_id[c.id] %>

          <% if current_user&.student? && current_user == user %>
            <% if pending_request %>
              <span class="inline-flex w-full items-center justify-center rounded bg-emerald-50 px-2 py-1 text-sm font-semibold text-emerald-700 sm:w-auto">
                사용 요청 중
              </span>
            <% else %>
              <%= button_to "사용요청",
                    request_user_coupon_use_path(user, c),
                    method: :post,
                    form: { data: { turbo_frame: "_top", turbo_submits_with: "처리중..." } },
                    class: "w-full px-2 py-1 text-sm rounded bg-emerald-500 text-white hover:bg-emerald-600 sm:w-auto" %>
            <% end %>
          <% elsif pending_request %>
            <%= button_to "사용 승인",
                  approve_coupon_use_request_path(pending_request),
                  method: :patch,
                  form: { data: { turbo_frame: "_top", turbo_submits_with: "처리중..." } },
                  class: "w-full px-2 py-1 text-sm rounded bg-amber-500 text-white hover:bg-amber-600 sm:w-auto" %>
          <% else %>
            <%= button_to t('ui.buttons.use_coupon'),
                  use_user_coupon_path(user, c),
                  method: :post,
                  form: { data: { turbo_submits_with: "처리중..." } },
                  class: "w-full px-2 py-1 text-sm rounded bg-emerald-500 text-white hover:bg-emerald-600 sm:w-auto" %>
          <% end %>
        </div>
      </li>
    <% end %>
  </ul>
<% else %>
  <p class="text-sm text-gray-500"><%= t("empty.issued_coupons") %></p>
<% end %>
