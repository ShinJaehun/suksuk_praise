<section class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
  <details>
    <summary class="cursor-pointer text-base font-semibold text-slate-900">
      담당 선생님 배정 · <%= assigned_teacher_ids.size %>명 선택됨
    </summary>

    <%= hidden_field_tag "classroom[teacher_ids][]", "" %>

    <div class="mt-4 grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3">
      <% assignable_teachers.each do |teacher| %>
        <label class="flex min-w-0 items-center gap-3 rounded-xl border border-slate-200 p-3 hover:bg-slate-50">
          <%= check_box_tag "classroom[teacher_ids][]",
                teacher.id,
                assigned_teacher_ids.include?(teacher.id),
                id: "classroom_teacher_ids_#{teacher.id}",
                class: "rounded border-slate-300 text-sky-600 focus:ring-sky-500" %>
          <%= user_avatar_image(
                teacher,
                size: 128,
                class: "h-10 w-10 shrink-0 rounded-xl border border-slate-200 bg-slate-100 object-cover",
                alt: "#{teacher.name} avatar"
              ) %>
          <span class="min-w-0">
            <span class="block truncate text-sm font-semibold text-slate-800"><%= teacher.name %></span>
            <span class="block truncate text-xs text-slate-500"><%= teacher.email %></span>
          </span>
        </label>
      <% end %>
    </div>

    <div class="mt-5 flex justify-end">
      <%= form.submit "담당 선생님 저장",
            class: "inline-flex items-center justify-center rounded-lg bg-blue-600 px-4 py-3 text-sm font-semibold text-white hover:bg-blue-700" %>
    </div>
  </details>
</section>
