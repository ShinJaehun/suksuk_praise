<section class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
  <div class="mb-4">
    <h2 class="text-base font-semibold text-slate-900">담당 선생님 배정</h2>
  </div>

  <%= hidden_field_tag "classroom[teacher_ids][]", "" %>

  <div class="space-y-3">
    <% assignable_teachers.each do |teacher| %>
      <label class="flex items-start gap-3 rounded-xl border border-slate-200 p-4 hover:bg-slate-50">
        <%= check_box_tag "classroom[teacher_ids][]",
              teacher.id,
              assigned_teacher_ids.include?(teacher.id),
              id: "classroom_teacher_ids_#{teacher.id}",
              class: "mt-1 rounded border-slate-300 text-sky-600 focus:ring-sky-500" %>
        <span class="min-w-0 space-y-1">
          <span class="block text-sm font-semibold text-slate-800"><%= teacher.name %></span>
          <span class="block break-all text-sm text-slate-500"><%= teacher.email %></span>
        </span>
      </label>
    <% end %>
  </div>
</section>
