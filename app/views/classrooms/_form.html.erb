<%= form_with model: classroom, local: true do |f| %>
  <div class="space-y-6">
    <% if classroom.errors[:base].any? %>
      <div class="rounded-lg border border-rose-200 bg-rose-50 px-3 py-2 text-sm text-rose-700">
        <%= classroom.errors.full_messages_for(:base).to_sentence %>
      </div>
    <% end %>

    <% if policy(classroom).manage_structure? %>
      <section class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
        <div class="mb-4">
          <h2 class="text-base font-semibold text-slate-900"><%= t("classrooms.form.basic_info") %></h2>
        </div>

        <div class="space-y-2 sm:max-w-3xl">
          <% name_has_errors = classroom.errors[:name].any? %>
          <%= f.label :name, t("classrooms.form.name_label"), class: "block text-sm font-semibold text-slate-800" %>
          <%= f.text_field :name,
                placeholder: t("classrooms.form.name_placeholder"),
                class: "block w-full rounded-xl border px-4 py-3 text-sm text-slate-900 shadow-sm placeholder:text-slate-400 focus:outline-none focus:ring-2 #{name_has_errors ? "border-rose-400 focus:border-rose-500 focus:ring-rose-100" : "border-slate-300 focus:border-sky-500 focus:ring-sky-100"}" %>
          <% if name_has_errors %>
            <p class="text-sm text-rose-600"><%= classroom.errors.full_messages_for(:name).to_sentence %></p>
          <% else %>
            <p class="text-sm text-slate-500"><%= t("classrooms.form.name_hint") %></p>
          <% end %>
        </div>

        <div class="mt-5 grid gap-4 sm:max-w-3xl sm:grid-cols-2">
          <% if current_user.admin? %>
            <div class="space-y-2">
              <% school_has_errors = classroom.errors[:school].any? || classroom.errors[:school_id].any? %>
              <%= f.label :school_id, t("classrooms.form.school_label"), class: "block text-sm font-semibold text-slate-800" %>
              <%= f.collection_select :school_id,
                    @school_options,
                    :id,
                    :name,
                    { include_blank: t("classrooms.form.school_prompt") },
                    class: "block w-full rounded-xl border px-4 py-3 text-sm text-slate-900 shadow-sm focus:outline-none focus:ring-2 #{school_has_errors ? "border-rose-400 focus:border-rose-500 focus:ring-rose-100" : "border-slate-300 focus:border-sky-500 focus:ring-sky-100"}" %>
              <% if school_has_errors %>
                <p class="text-sm text-rose-600"><%= (classroom.errors.full_messages_for(:school) + classroom.errors.full_messages_for(:school_id)).uniq.to_sentence %></p>
              <% end %>
            </div>
          <% elsif current_user.school_membership&.manager? %>
            <div class="space-y-2">
              <span class="block text-sm font-semibold text-slate-800"><%= t("classrooms.form.school_label") %></span>
              <p class="rounded-xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-700"><%= current_user.school_membership.school.name %></p>
            </div>
          <% end %>

          <div class="space-y-2">
            <% grade_has_errors = classroom.errors[:grade].any? %>
            <%= f.label :grade, t("classrooms.form.grade_label"), class: "block text-sm font-semibold text-slate-800" %>
            <%= f.select :grade,
                  (1..6).map { |grade| [t("classrooms.index.grade", grade: grade), grade] },
                  { include_blank: t("classrooms.form.grade_prompt") },
                  class: "block w-full rounded-xl border px-4 py-3 text-sm text-slate-900 shadow-sm focus:outline-none focus:ring-2 #{grade_has_errors ? "border-rose-400 focus:border-rose-500 focus:ring-rose-100" : "border-slate-300 focus:border-sky-500 focus:ring-sky-100"}" %>
            <% if grade_has_errors %>
              <p class="text-sm text-rose-600"><%= classroom.errors.full_messages_for(:grade).to_sentence %></p>
            <% end %>
          </div>
        </div>
      </section>

      <aside class="rounded-2xl border border-sky-200 bg-sky-50 p-4 text-sm text-sky-800">
        <p><%= t("classrooms.form.teacher_assignment_managed_in_school") %></p>
        <% if classroom.school.present? %>
          <%= link_to t("classrooms.form.manage_teachers"),
                school_teachers_path(classroom.school),
                class: "mt-2 inline-flex font-semibold text-sky-700 underline hover:text-sky-900" %>
        <% end %>
      </aside>
    <% end %>

    <% if policy(classroom).manage_operations? %>
      <section class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
        <div class="mb-4">
          <h2 class="text-base font-semibold text-slate-900">칭찬왕 설정</h2>
        </div>

        <div class="space-y-3">
          <label class="flex items-start gap-3 rounded-xl border border-slate-200 p-4 hover:bg-slate-50">
            <%= f.check_box :daily_compliment_king_enabled,
                  class: "mt-1 rounded border-slate-300 text-sky-600 focus:ring-sky-500" %>
            <span class="space-y-1">
              <span class="block text-sm font-semibold text-slate-800">일간 칭찬왕</span>
              <span class="block text-sm text-slate-500">하루 단위로 가장 많이 칭찬받은 학생을 표시합니다.</span>
            </span>
          </label>

          <label class="flex items-start gap-3 rounded-xl border border-slate-200 p-4 hover:bg-slate-50">
            <%= f.check_box :weekly_compliment_king_enabled,
                  class: "mt-1 rounded border-slate-300 text-sky-600 focus:ring-sky-500" %>
            <span class="space-y-1">
              <span class="block text-sm font-semibold text-slate-800">주간 칭찬왕</span>
              <span class="block text-sm text-slate-500">이번 주 기준으로 가장 많이 칭찬받은 학생을 표시합니다.</span>
            </span>
          </label>

          <label class="flex items-start gap-3 rounded-xl border border-slate-200 p-4 hover:bg-slate-50">
            <%= f.check_box :monthly_compliment_king_enabled,
                  class: "mt-1 rounded border-slate-300 text-sky-600 focus:ring-sky-500" %>
            <span class="space-y-1">
              <span class="block text-sm font-semibold text-slate-800">월간 칭찬왕</span>
              <span class="block text-sm text-slate-500">이번 달 기준으로 가장 많이 칭찬받은 학생을 표시합니다.</span>
            </span>
          </label>
        </div>
      </section>

      <section class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
        <div class="mb-4">
          <h2 class="text-base font-semibold text-slate-900">메시지 관리</h2>
        </div>

        <div class="space-y-2">
          <%= f.label :message_policy, "메시지 정책", class: "block text-sm font-semibold text-slate-800" %>
          <%= f.select :message_policy,
                [
                  ["메시지 사용 안 함", "disabled"],
                  ["답장만 허용", "replies_only"],
                  ["학생 먼저 메시지 허용", "student_initiated"]
                ],
                {},
                class: "block w-full rounded-xl border border-slate-300 px-4 py-3 text-sm text-slate-900 shadow-sm focus:border-sky-500 focus:outline-none focus:ring-2 focus:ring-sky-100 sm:max-w-md" %>
          <p class="text-sm text-slate-500">학생 메시지 영역과 작성 권한을 교실별로 설정합니다.</p>
        </div>
      </section>
    <% end %>

    <div class="flex justify-end">
      <%= f.submit submit_label,
            class: "inline-flex items-center justify-center rounded-lg bg-blue-600 px-4 py-3 text-sm font-semibold text-white hover:bg-blue-700" %>
    </div>
  </div>
<% end %>
