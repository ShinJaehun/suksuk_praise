<section class="mx-auto w-full max-w-6xl space-y-5 pt-4">
  <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
    <div class="flex flex-col items-start justify-between gap-3 sm:flex-row sm:items-center">
      <h1 class="text-2xl font-extrabold tracking-tight text-slate-900"><%= @classroom.name %></h1>

      <div class="flex w-full flex-wrap items-center gap-2 sm:w-auto">
        <% @enabled_compliment_king_periods.each do |period| %>
          <%= button_to t("ui.buttons.refresh_king_for.#{period}"),
                refresh_compliment_king_classroom_path(@classroom, period: period),
                method: :post,
                form: { data: { turbo_submits_with: t("ui.processing") } },
                class: "w-full rounded-lg border border-slate-300 bg-slate-100 px-3 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-200 sm:w-auto" %>
        <% end %>

        <% if @can_manage_classroom %>
          <%= link_to "교실 관리",
                edit_classroom_path(@classroom),
                class: "w-full rounded-lg border border-sky-300 bg-sky-50 px-3 py-2 text-sm font-semibold text-sky-700 hover:bg-sky-100 sm:w-auto" %>
        <% end %>
      </div>
    </div>
  </div>

  <% if @compliment_king_period_cards.present? %>
    <section class="<%= compliment_king_board_classes(@compliment_king_period_cards.size) %>">
      <% @compliment_king_period_cards.each do |card| %>
        <%= turbo_frame_tag card[:frame_id], class: "hidden" %>
      <% end %>
    </section>
  <% end %>

  <section class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
    <%= turbo_frame_tag "students_list_#{@classroom.id}" do %>
      <div id="students_grid_<%= @classroom.id %>" class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
        <%= render partial: "users/user", collection: @students, as: :user, locals: { classroom: @classroom } %>
      </div>
    <% end %>
  </section>
</section>
