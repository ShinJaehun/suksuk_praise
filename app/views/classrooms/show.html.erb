<section class="mx-auto w-full max-w-6xl space-y-5 pt-4">
  <%= turbo_stream_from @classroom, :student_card_alerts %>

  <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
    <div class="flex flex-col items-start justify-between gap-3 sm:flex-row sm:items-center">
      <h1 class="min-w-0 max-w-full break-words text-2xl font-extrabold tracking-tight text-slate-900"><%= @classroom.name %></h1>

      <div class="flex w-full flex-col items-stretch gap-2 sm:w-auto sm:flex-row sm:flex-wrap sm:items-center">
        <% @enabled_compliment_king_periods.each do |period| %>
          <%= button_to t("ui.buttons.refresh_king_for.#{period}"),
                refresh_compliment_king_classroom_path(@classroom, period: period),
                method: :post,
                form: { data: { turbo_submits_with: t("ui.processing") } },
                class: "w-full rounded-lg border border-slate-300 bg-slate-100 px-3 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-200 sm:w-auto" %>
        <% end %>

        <% if @can_manage_classroom %>
          <%= link_to "교실 관리",
                edit_classroom_path(@classroom),
                class: "w-full rounded-lg border border-sky-300 bg-sky-50 px-3 py-2 text-sm font-semibold text-sky-700 hover:bg-sky-100 sm:w-auto" %>
          <%= link_to "구성원 관리",
                classroom_members_path(@classroom),
                class: "w-full rounded-lg border border-indigo-300 bg-indigo-50 px-3 py-2 text-sm font-semibold text-indigo-700 hover:bg-indigo-100 sm:w-auto" %>
        <% end %>
      </div>
    </div>

    <div class="mt-4 pl-2">
      <% if @homeroom_teachers.any? %>
        <div class="flex flex-wrap items-center gap-3">
          <% @homeroom_teachers.each do |teacher| %>
            <div class="flex min-w-0 max-w-full items-center gap-2">
              <%= user_avatar_image(
                    teacher,
                    size: 128,
                    class: "h-10 w-10 shrink-0 rounded-lg border border-slate-200 bg-slate-100 object-cover",
                    alt: "#{display_name(teacher)} avatar"
                  ) %>
              <span class="min-w-0 truncate text-sm font-medium text-slate-800"><%= display_name(teacher) %></span>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="mt-2 text-sm text-slate-500">담당 교사 없음</p>
      <% end %>
    </div>
  </div>

  <% if @compliment_king_period_cards.present? %>
    <section class="<%= compliment_king_board_classes(@compliment_king_period_cards.size) %>">
      <% @compliment_king_period_cards.each do |card| %>
        <%= turbo_frame_tag card[:frame_id], class: "hidden" %>
      <% end %>
    </section>
  <% end %>

  <section class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
    <%= turbo_frame_tag "students_list_#{@classroom.id}" do %>
      <% if @students.any? %>
        <div id="students_grid_<%= @classroom.id %>" class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
          <%= render partial: "users/user",
                collection: @students,
                as: :user,
                locals: {
                  classroom: @classroom,
                  student_ids_with_pending_coupon_use_requests: @student_ids_with_pending_coupon_use_requests,
                  student_ids_with_unread_student_messages: @student_ids_with_unread_student_messages,
                  today_compliment_counts_by_student_id: @today_compliment_counts_by_student_id
                } %>
        </div>
      <% else %>
        <div class="rounded-xl border border-dashed border-slate-300 bg-slate-50 px-5 py-8 text-center">
          <h2 class="text-lg font-bold text-slate-900">아직 학생이 없습니다</h2>
          <p class="mt-2 text-sm text-slate-600">
            구성원 관리에서 학생을 추가하거나 여러 학생을 한 번에 생성할 수 있어요.
          </p>
          <div class="mt-5 flex flex-col justify-center gap-2 sm:flex-row">
            <%= link_to "구성원 관리로 이동",
                  classroom_members_path(@classroom, anchor: "student-management"),
                  data: { turbo_frame: "_top" },
                  class: "inline-flex items-center justify-center rounded-lg bg-emerald-600 px-4 py-2 text-sm font-semibold text-white hover:bg-emerald-700" %>
          </div>
        </div>
      <% end %>
    <% end %>
  </section>
</section>
