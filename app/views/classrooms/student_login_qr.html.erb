<section class="mx-auto w-full max-w-xl space-y-5 pt-4">
  <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
    <div class="space-y-1">
      <p class="text-sm font-semibold text-slate-500"><%= @classroom.name %></p>
      <h1 class="text-2xl font-extrabold tracking-tight text-slate-900">로그인 QR 코드</h1>
      <p class="text-sm text-slate-600">
        학생은 이 QR 코드로 접속한 뒤 PIN으로 로그인할 수 있습니다.
      </p>
    </div>

    <%= link_to "교실 관리로 돌아가기",
          edit_classroom_path(@classroom),
          class: "inline-flex items-center justify-center rounded-lg border border-slate-300 bg-white px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-50" %>
  </div>

  <section class="rounded-2xl border border-slate-200 bg-white p-5 text-center shadow-sm">
    <div class="mx-auto inline-block rounded-xl border border-slate-200 bg-white p-4">
      <%= @student_login_qr_svg.html_safe %>
    </div>

    <p class="mt-5 break-all rounded-lg border border-slate-200 bg-slate-50 px-4 py-3 text-left text-sm font-medium text-slate-800">
      <%= @student_login_url %>
    </p>
  </section>
</section>
