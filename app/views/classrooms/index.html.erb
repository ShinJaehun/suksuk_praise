<section class="mx-auto w-full max-w-6xl pt-4">
  <div class="mb-6 flex flex-col items-start justify-between gap-3 sm:flex-row sm:items-center">
    <h1 class="text-2xl font-extrabold tracking-tight text-slate-900"><%= @classrooms_index_title == "교실 관리" ? "교실" : @classrooms_index_title %></h1>

    <% if policy(Classroom).create? %>
      <%= link_to t('ui.buttons.new_classroom'),
            new_classroom_path,
            class: "inline-flex w-full justify-center items-center rounded-lg bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow hover:bg-emerald-700 sm:w-auto" %>
    <% end %>
  </div>

  <div class="<%= current_user.admin? ? "grid grid-cols-1 gap-6 lg:grid-cols-[minmax(0,1fr)_20rem]" : "" %>">
    <div>
  <% if @classrooms.any? %>
    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
      <% @classrooms.each do |classroom| %>
        <% teacher_count = @classroom_teacher_counts.fetch(classroom.id, 0) %>
        <% teacher = @classroom_teacher_previews.fetch(classroom.id, []).first %>
        <% student_count = @classroom_student_counts.fetch(classroom.id, 0) %>
        <% student_previews = @classroom_student_previews.fetch(classroom.id, []) %>

        <article class="flex min-h-64 flex-col justify-between rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
          <div class="min-w-0 space-y-5">
            <h2 class="truncate text-lg font-bold text-slate-900">
              <%= classroom.name %>
            </h2>
            <p class="text-xs font-medium text-slate-500">
              <% if classroom.school.nil? && classroom.grade.nil? %>
                미지정
              <% else %>
                <%= classroom.school&.name || "학교 미지정" %> · <%= classroom.grade ? "#{classroom.grade}학년" : "학년 미지정" %>
              <% end %>
            </p>

            <div class="space-y-3">
              <% if teacher %>
                <div class="flex min-w-0 items-center gap-2">
                  <%= user_avatar_image(
                        teacher,
                        size: 128,
                        class: "h-12 w-12 shrink-0 rounded-xl border border-slate-200 bg-slate-100 object-cover",
                        alt: "#{display_name(teacher)} avatar"
                      ) %>
                  <div class="flex min-w-0 items-center gap-1 text-sm">
                    <span class="min-w-0 truncate font-semibold text-slate-800"><%= display_name(teacher) %></span>
                    <% if teacher_count > 1 %>
                      <span class="shrink-0 whitespace-nowrap text-slate-500">외 <%= teacher_count - 1 %>명</span>
                    <% end %>
                  </div>
                </div>
              <% else %>
                <p class="text-sm text-slate-500">담당 선생님 없음</p>
              <% end %>

              <% if student_count.positive? %>
                <div class="flex min-w-0 items-center gap-3">
                  <div class="flex max-w-32 shrink-0 -space-x-2 overflow-hidden">
                    <% student_previews.each do |student| %>
                      <%= user_avatar_image(
                            student,
                            size: 128,
                            class: "h-8 w-8 rounded-xl border-2 border-white bg-slate-100 object-cover",
                            alt: "#{display_name(student)} avatar"
                          ) %>
                    <% end %>
                  </div>
                  <span class="shrink-0 whitespace-nowrap text-sm font-medium text-slate-600">학생 <%= student_count %>명</span>
                </div>
              <% else %>
                <p class="text-sm text-slate-500">학생 없음</p>
              <% end %>
            </div>
          </div>

          <div class="mt-6 flex items-center gap-2">
            <%= link_to "열기",
                  classroom_path(classroom),
                  class: "inline-flex flex-1 items-center justify-center rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-50" %>
            <% if @manageable_classroom_ids.include?(classroom.id) %>
              <%= link_to "관리",
                    edit_classroom_path(classroom),
                    class: "inline-flex flex-1 items-center justify-center rounded-lg border border-sky-300 bg-sky-50 px-3 py-2 text-sm font-semibold text-sky-700 hover:bg-sky-100" %>
            <% end %>
          </div>
        </article>
      <% end %>
    </div>
      <% else %>
        <div class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm">
          <div class="px-5 py-10 text-center text-sm text-slate-500">
            아직 교실이 없습니다.
          </div>
        </div>
      <% end %>
    </div>

    <% if current_user.admin? %>
      <aside class="rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
        <div class="mb-3 flex items-center justify-between gap-3">
          <h2 class="text-base font-bold text-slate-900">선생님</h2>
          <%= link_to "새 선생님 추가",
                new_admin_teacher_path,
                data: { turbo_frame: "modal" },
                class: "shrink-0 rounded-lg border border-slate-200 px-2.5 py-1.5 text-xs font-semibold text-slate-700 hover:bg-slate-50" %>
        </div>

        <% if @teacher_assignment_rows.any? %>
          <div class="space-y-2 lg:max-h-[calc(100vh-12rem)] lg:overflow-y-auto">
            <% @teacher_assignment_rows.each do |row| %>
              <% teacher = row[:teacher] %>
              <% classroom_names = row[:classroom_names] %>
              <% visible_classroom_names = classroom_names.first(2) %>

              <a href="<%= edit_admin_teacher_path(teacher) %>"
                 data-turbo-frame="modal"
                 class="flex min-w-0 items-center gap-3 rounded-xl border border-slate-100 bg-slate-50 px-3 py-2 hover:bg-slate-100">
                <%= user_avatar_image(
                      teacher,
                      size: 128,
                      class: "h-8 w-8 shrink-0 rounded-xl border border-slate-200 bg-slate-100 object-cover",
                      alt: "#{display_name(teacher)} avatar"
                    ) %>
                <div class="min-w-0 flex-1">
                  <div class="flex min-w-0 items-center justify-between gap-2">
                    <span class="min-w-0 truncate text-sm font-semibold text-slate-900"><%= display_name(teacher) %></span>
                    <span class="shrink-0 whitespace-nowrap text-xs font-medium text-slate-500">담당 <%= row[:classroom_count] %>개</span>
                  </div>
                  <p class="mt-0.5 min-w-0 truncate whitespace-nowrap text-xs text-slate-500">
                    <% if classroom_names.any? %>
                      <%= visible_classroom_names.join(", ") %>
                      <% if classroom_names.size > visible_classroom_names.size %>
                        외 <%= classroom_names.size - visible_classroom_names.size %>개
                      <% end %>
                    <% else %>
                      미배정
                    <% end %>
                  </p>
                </div>
              </a>
            <% end %>
          </div>
        <% else %>
          <div class="rounded-xl border border-dashed border-slate-200 px-3 py-6 text-center text-sm text-slate-500">
            등록된 선생님이 없습니다.
          </div>
        <% end %>
      </aside>
    <% end %>
  </div>

  <% if current_user.admin? %>
    <section class="mt-6 border-t border-slate-200 pt-6">
      <div class="mb-3 flex items-center justify-between gap-3">
        <h2 class="text-lg font-bold text-slate-900">학교</h2>
        <%= link_to "학교 추가",
              new_admin_school_path,
              data: { turbo_frame: "modal" },
              class: "shrink-0 rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-50" %>
      </div>

      <% if @schools.any? %>
        <div class="divide-y divide-slate-200 border-y border-slate-200">
          <% @schools.each do |school| %>
            <div class="flex items-center justify-between gap-4 py-3">
              <div class="min-w-0">
                <p class="truncate text-sm font-semibold text-slate-900"><%= school.name %></p>
                <p class="mt-0.5 text-xs text-slate-500">소속 교실 <%= @school_classroom_counts.fetch(school.id, 0) %>개</p>
              </div>
              <%= link_to "수정",
                    edit_admin_school_path(school),
                    data: { turbo_frame: "modal" },
                    class: "shrink-0 rounded-lg border border-slate-300 bg-white px-3 py-1.5 text-xs font-semibold text-slate-700 hover:bg-slate-50" %>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="border-y border-slate-200 py-6 text-center text-sm text-slate-500">등록된 학교가 없습니다.</p>
      <% end %>
    </section>
  <% end %>
</section>
