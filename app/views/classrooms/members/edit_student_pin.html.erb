<%= turbo_frame_tag :modal do %>
  <div class="fixed inset-0 z-50 flex items-center justify-center bg-black/50 p-4" data-controller="modal" role="dialog" aria-modal="true">
    <div class="w-full max-w-md max-h-[calc(100vh-2rem)] overflow-y-auto rounded-lg bg-white p-6 shadow-lg">
      <div class="space-y-4">
        <h2 class="text-xl font-bold text-slate-900"><%= t("students.members.pin_reset.title") %></h2>

        <p class="text-sm leading-6 text-slate-600">
          <%= t("students.members.pin_reset.description") %>
        </p>

        <% if @student_pin_error.present? %>
          <div class="rounded-lg border border-rose-200 bg-rose-50 px-3 py-2 text-sm font-medium text-rose-700">
            <%= @student_pin_error %>
          </div>
        <% end %>

        <%= form_tag classroom_member_student_pin_path(@classroom),
              method: :patch,
              class: "space-y-4",
              data: {
                turbo_frame: :modal,
                turbo_confirm: t("students.members.pin_reset.confirm"),
                turbo_submits_with: t("ui.processing")
              } do %>
          <div>
            <%= label_tag :student_pin, t("students.members.pin_reset.label"), class: "block text-sm font-semibold text-slate-700" %>
            <%= password_field_tag :student_pin,
                  "",
                  maxlength: 4,
                  inputmode: "numeric",
                  pattern: "\\d{4}",
                  autocomplete: "off",
                  class: "mt-1 block w-full rounded-lg border border-slate-300 px-3 py-2 text-sm shadow-sm focus:border-sky-500 focus:outline-none focus:ring-2 focus:ring-sky-100" %>
          </div>

          <div class="mt-4 flex flex-col gap-2 sm:flex-row">
            <%= button_tag type: "submit",
                  data: { testid: "active-student-pin-reset-submit" },
                  class: "inline-flex w-full items-center justify-center rounded-lg border border-blue-700 bg-blue-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-blue-700 sm:w-auto" do %>
              <%= t("students.members.pin_reset.submit") %>
            <% end %>
            <button type="button" data-action="modal#close" class="inline-flex w-full items-center justify-center rounded-lg bg-gray-300 px-4 py-2 text-sm font-semibold text-slate-700 sm:w-auto">닫기</button>
          </div>
        <% end %>
      </div>
    </div>
  </div>
<% end %>
