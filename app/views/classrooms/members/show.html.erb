<section class="mx-auto w-full max-w-5xl space-y-6 pt-4">
  <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
    <div class="space-y-1">
      <h1 class="text-2xl font-extrabold tracking-tight text-slate-900">구성원 관리</h1>
    </div>

    <div class="flex flex-col gap-2 sm:flex-row">
      <%= link_to "교실 설정",
            edit_classroom_path(@classroom),
            class: "inline-flex items-center justify-center rounded-lg border border-sky-300 bg-sky-50 px-4 py-2 text-sm font-semibold text-sky-700 hover:bg-sky-100" %>
      <%= link_to "교실로 돌아가기",
            classroom_path(@classroom),
            class: "inline-flex items-center justify-center rounded-lg border border-slate-300 bg-white px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-50" %>
    </div>
  </div>

  <section class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
    <h2 class="text-2xl font-extrabold tracking-tight text-slate-900"><%= @classroom.name %></h2>
  </section>

  <section class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
    <div class="mb-4">
      <h2 class="text-base font-semibold text-slate-900">학생 로그인</h2>
      <p class="mt-1 text-sm text-slate-500">
        학생은 이 주소에서 PIN으로 로그인할 수 있습니다.
      </p>
    </div>

    <div data-controller="clipboard" class="space-y-3">
      <div class="flex flex-col gap-3 rounded-lg border border-slate-200 bg-slate-50 p-3 sm:flex-row sm:items-center">
        <p data-clipboard-target="source"
           class="min-w-0 flex-1 break-all text-sm font-medium text-slate-800">
          <%= public_student_login_url(student_login_token: @classroom.student_login_token) %>
        </p>

        <div class="flex shrink-0 flex-col gap-2 sm:flex-row sm:items-center">
          <button type="button"
                  data-action="clipboard#copy"
                  class="inline-flex items-center justify-center rounded-lg border border-slate-300 bg-white px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-50">
            URL 복사
          </button>
          <span data-clipboard-target="status" class="text-sm text-slate-500 sm:max-w-52" aria-live="polite"></span>
        </div>
      </div>

      <div class="flex flex-col gap-2 sm:flex-row">
        <%= link_to "QR 코드 보기",
              student_login_qr_classroom_path(@classroom),
              class: "inline-flex items-center justify-center rounded-lg border border-slate-300 bg-white px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-50" %>
        <%= link_to "QR 코드 다운로드",
              download_student_login_qr_classroom_path(@classroom),
              class: "inline-flex items-center justify-center rounded-lg border border-slate-300 bg-white px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-50" %>
      </div>
    </div>

    <div class="mt-5 rounded-lg border border-rose-200 bg-rose-50 px-4 py-3">
      <p class="text-sm font-semibold text-rose-900">학생 로그인 주소 재발급</p>
      <p class="mt-1 text-sm text-rose-700">
        학생 로그인 주소가 외부에 노출되었거나 새 주소를 다시 안내해야 할 때만 재발급하세요.
      </p>
      <p class="mt-1 text-sm text-rose-700">
        재발급 후에는 기존 주소로 학생 로그인 화면에 접근할 수 없습니다.
      </p>

      <div class="mt-3">
        <%= button_to "학생 로그인 주소 재발급",
              regenerate_student_login_token_classroom_path(@classroom),
              method: :patch,
              form: {
                data: { turbo: false },
                onsubmit: "return confirm('학생 로그인 주소를 재발급하면 기존에 배포한 주소는 더 이상 사용할 수 없습니다. 계속할까요?')"
              },
              class: "inline-flex items-center justify-center rounded-lg border border-rose-300 bg-white px-4 py-2 text-sm font-semibold text-rose-700 hover:bg-rose-100" %>
      </div>
    </div>
  </section>

  <section id="student-management" class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
    <div class="mb-4">
      <h2 class="text-base font-semibold text-slate-900">학생 관리</h2>
    </div>

    <div class="flex flex-col gap-3 sm:flex-row sm:flex-wrap">
      <%= link_to t("ui.buttons.create_student"),
            new_classroom_student_path(@classroom),
            data: { turbo_frame: "modal" },
            class: "inline-flex items-center justify-center rounded-lg bg-emerald-600 px-4 py-2 text-sm font-semibold text-white hover:bg-emerald-700" %>

      <%= link_to t("ui.buttons.bulk_create_students"),
            bulk_new_classroom_students_path(@classroom),
            data: { turbo_frame: "modal" },
            class: "inline-flex items-center justify-center rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white hover:bg-indigo-700" %>
    </div>

    <div class="mt-5 flex flex-wrap gap-2">
      <% %w[active inactive all].each do |status| %>
        <% active_filter = @membership_status_filter == status %>
        <%= link_to t("students.members.filters.#{status}"),
              classroom_members_path(@classroom, status: status),
              class: [
                "inline-flex items-center rounded-lg border px-3 py-2 text-sm font-semibold",
                active_filter ? "border-blue-500 bg-blue-50 text-blue-700" : "border-slate-300 bg-white text-slate-700 hover:bg-slate-50"
              ].join(" ") %>
      <% end %>
    </div>

    <div class="mt-5 space-y-2">
      <% if @student_memberships.any? %>
        <% @student_memberships.each do |membership| %>
          <div class="flex flex-col gap-3 rounded-lg border border-slate-200 px-3 py-3 <%= "opacity-60" if membership.inactive? %> sm:flex-row sm:items-center sm:justify-between">
            <div class="flex min-w-0 items-center gap-2">
              <%= link_to display_name(membership.user),
                    classroom_student_path(@classroom, membership.user),
                    class: "min-w-0 truncate text-sm font-semibold text-sky-700 hover:underline" %>

              <% if membership.inactive? %>
                <span class="shrink-0 rounded-full bg-slate-100 px-2 py-0.5 text-xs font-semibold text-slate-600">
                  <%= t("ui.inactive") %>
                </span>
              <% end %>
            </div>

            <div class="flex shrink-0 flex-wrap gap-2">
              <%= link_to "계정 관리",
                    edit_classroom_student_path(@classroom, membership.user),
                    class: "inline-flex items-center justify-center rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-50" %>

              <% if membership.active? %>
                <%= button_to t("students.actions.deactivate"),
                      deactivate_classroom_student_path(@classroom, membership.user),
                      method: :patch,
                      data: { turbo_confirm: t("students.deactivate.confirm") },
                      class: "inline-flex items-center justify-center rounded-lg border border-rose-300 bg-white px-3 py-2 text-sm font-semibold text-rose-700 hover:bg-rose-50" %>
              <% else %>
                <%= button_to t("students.actions.reactivate"),
                      reactivate_classroom_student_path(@classroom, membership.user),
                      method: :patch,
                      class: "inline-flex items-center justify-center rounded-lg border border-emerald-300 bg-white px-3 py-2 text-sm font-semibold text-emerald-700 hover:bg-emerald-50" %>
              <% end %>
            </div>
          </div>
        <% end %>
      <% else %>
        <p class="rounded-lg border border-dashed border-slate-300 bg-slate-50 px-4 py-5 text-center text-sm text-slate-600">
          <%= t("students.members.empty") %>
        </p>
      <% end %>
    </div>
  </section>

  <% if current_user.admin? %>
    <%= form_with model: @classroom, local: true do |f| %>
      <%= render "classrooms/teacher_assignment_fields",
            assignable_teachers: @assignable_teachers,
            assigned_teacher_ids: @assigned_teacher_ids,
            form: f %>
    <% end %>
  <% end %>
</section>
