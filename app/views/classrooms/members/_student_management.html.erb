<section id="student-management" class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
  <div class="mb-4">
    <h2 class="text-base font-semibold text-slate-900">학생 관리</h2>
  </div>

  <div class="flex flex-col gap-3 sm:flex-row sm:flex-wrap">
    <%= link_to t("ui.buttons.create_student"),
          new_classroom_student_path(@classroom, return_to: "members"),
          data: { turbo_frame: "modal" },
          class: "inline-flex items-center justify-center rounded-lg bg-emerald-600 px-4 py-2 text-sm font-semibold text-white hover:bg-emerald-700" %>

    <%= link_to t("ui.buttons.bulk_create_students"),
          bulk_new_classroom_students_path(@classroom, return_to: "members"),
          data: { turbo_frame: "modal" },
          class: "inline-flex items-center justify-center rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white hover:bg-indigo-700" %>
  </div>

  <div class="mt-5 flex flex-wrap gap-2">
    <% %w[active inactive all].each do |status| %>
      <% active_filter = @membership_status_filter == status %>
      <%= link_to t("students.members.filters.#{status}"),
            classroom_members_path(@classroom, status: status),
            class: [
              "inline-flex items-center rounded-lg border px-3 py-2 text-sm font-semibold",
              active_filter ? "border-blue-500 bg-blue-50 text-blue-700" : "border-slate-300 bg-white text-slate-700 hover:bg-slate-50"
            ].join(" ") %>
    <% end %>
  </div>

  <div class="mt-5 flex justify-end">
    <%= form_with url: classroom_member_student_names_path(@classroom),
          method: :patch,
          local: true,
          html: { id: "student_names_form" } do %>
      <%= hidden_field_tag :status, @membership_status_filter %>
      <%= submit_tag t("students.members.update_names.submit"),
            class: "inline-flex items-center justify-center rounded-lg bg-blue-600 px-4 py-2 text-sm font-semibold text-white hover:bg-blue-700" %>
    <% end %>
  </div>

  <div class="mt-5 overflow-hidden rounded-xl border border-slate-200">
    <% if @student_memberships.any? %>
      <div class="divide-y divide-slate-200">
        <% @student_memberships.each do |membership| %>
          <% student = membership.user %>
          <div class="flex flex-wrap items-center gap-3 px-3 py-2 <%= "bg-slate-50 opacity-70" if membership.inactive? %> md:flex-nowrap">
            <%= user_avatar_image(
                  student,
                  size: 64,
                  class: "h-9 w-9 shrink-0 rounded-lg border border-slate-200 bg-slate-100 object-cover",
                  alt: "#{display_name(student)} avatar"
                ) %>

            <div class="min-w-[12rem] flex-1">
              <%= label_tag "student_name_#{membership.id}", t("students.members.name_label"), class: "sr-only" %>
              <%= text_field_tag "students[#{membership.id}][name]",
                    (@submitted_student_names || {}).fetch(membership.id.to_s, student.name),
                    id: "student_name_#{membership.id}",
                    form: "student_names_form",
                    class: "block w-full rounded-lg border border-slate-300 px-3 py-2 text-sm font-medium text-slate-900 shadow-sm focus:border-sky-500 focus:outline-none focus:ring-2 focus:ring-sky-100" %>

              <% if (@student_name_errors_by_membership_id || {})[membership.id.to_s].present? %>
                <p class="mt-1 text-sm font-medium text-rose-700">
                  <%= @student_name_errors_by_membership_id[membership.id.to_s] %>
                </p>
              <% end %>
            </div>

            <% if membership.inactive? %>
              <span class="sr-only"><%= t("ui.inactive") %> 학생</span>
            <% end %>

            <div class="flex shrink-0 flex-nowrap gap-2">
              <%= link_to "계정 관리",
                    edit_classroom_student_path(@classroom, student),
                    class: "inline-flex items-center justify-center rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-50" %>

              <% if membership.active? %>
                <%= button_to t("students.actions.deactivate"),
                      deactivate_classroom_student_path(@classroom, student),
                      method: :patch,
                      data: { turbo_confirm: t("students.deactivate.confirm") },
                      class: "inline-flex items-center justify-center rounded-lg border border-rose-300 bg-white px-3 py-2 text-sm font-semibold text-rose-700 hover:bg-rose-50" %>
              <% else %>
                <%= button_to t("students.actions.reactivate"),
                      reactivate_classroom_student_path(@classroom, student),
                      method: :patch,
                      class: "inline-flex items-center justify-center rounded-lg border border-emerald-300 bg-white px-3 py-2 text-sm font-semibold text-emerald-700 hover:bg-emerald-50" %>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="border border-dashed border-slate-300 bg-slate-50 px-4 py-5 text-center text-sm text-slate-600">
        <%= t("students.members.empty") %>
      </p>
    <% end %>
  </div>
</section>
