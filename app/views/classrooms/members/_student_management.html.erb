<% member_status = @member_status || "active" %>
<% member_counts = @student_member_counts || { "active" => 0, "inactive" => 0, "all" => @student_memberships.size } %>

<section id="student-management" class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
  <div class="flex flex-col gap-4">
    <div class="flex flex-col gap-3 lg:flex-row lg:items-center lg:justify-between">
      <h2 class="text-base font-semibold text-slate-900"><%= t("students.members.title") %></h2>

      <nav class="inline-flex w-full overflow-hidden rounded-lg border border-slate-200 bg-slate-50 p-1 text-sm font-semibold sm:w-auto" aria-label="<%= t("students.members.title") %>">
        <% %w[active inactive all].each do |status| %>
          <% selected = member_status == status %>
          <% filter_label = safe_join([
               t("students.members.filters.#{status}"),
               content_tag(:span, member_counts.fetch(status, 0), class: "ml-1 tabular-nums")
             ], " ") %>
          <%= link_to filter_label,
                classroom_members_path(@classroom, status: status),
                class: [
                  "flex-1 whitespace-nowrap rounded-md px-3 py-1.5 text-center sm:flex-none",
                  selected ? "bg-white text-slate-900 shadow-sm" : "text-slate-600 hover:text-slate-900"
                ].join(" "),
                aria: { current: (selected ? "page" : nil) } %>
        <% end %>
      </nav>
    </div>

    <div class="flex flex-col gap-3 lg:flex-row lg:items-center lg:justify-between">
      <div id="student-creation-actions" class="flex flex-wrap items-center gap-2">
        <%= link_to t("ui.buttons.create_student"),
              new_classroom_student_path(@classroom, return_to: "members"),
              data: { turbo_frame: "modal" },
              class: "inline-flex min-h-10 items-center justify-center rounded-lg bg-emerald-600 px-4 py-2 text-sm font-semibold text-white hover:bg-emerald-700 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-emerald-500 focus-visible:ring-offset-2" %>

        <%= link_to t("ui.buttons.bulk_create_students"),
              bulk_new_classroom_students_path(@classroom, return_to: "members"),
              data: { turbo_frame: "modal" },
              class: "inline-flex min-h-10 items-center justify-center rounded-lg border border-slate-300 bg-white px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-50 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-sky-500 focus-visible:ring-offset-2" %>
      </div>

      <div id="student-bulk-management-actions" class="flex flex-wrap items-center gap-2">
        <%= link_to t("students.members.actions.edit_names"),
              classroom_edit_member_student_names_path(@classroom, status: member_status),
              data: { turbo_frame: "modal" },
              class: "inline-flex min-h-10 items-center justify-center rounded-lg border border-slate-300 bg-white px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-50 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-sky-500 focus-visible:ring-offset-2" %>

        <% if member_counts.fetch("active", 0).positive? %>
          <%= link_to t("students.members.pin_reset.button"),
                classroom_edit_member_student_pin_path(@classroom),
                data: { turbo_frame: "modal" },
                class: "inline-flex min-h-10 items-center justify-center rounded-lg border border-amber-300 bg-amber-50 px-4 py-2 text-sm font-semibold text-amber-800 hover:bg-amber-100 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-amber-500 focus-visible:ring-offset-2" %>
        <% end %>
      </div>
    </div>
  </div>

  <div class="mt-5 overflow-hidden rounded-xl border border-slate-200">
    <% if @student_memberships.any? %>
      <div class="divide-y divide-slate-200">
        <% @student_memberships.each do |membership| %>
          <% student = membership.user %>
          <article id="<%= dom_id(membership, :member_row) %>" class="grid gap-3 px-4 py-3 <%= "bg-slate-50 opacity-75" if membership.inactive? %> md:grid-cols-[minmax(0,1fr)_auto] md:items-center">
            <div class="flex min-w-0 items-center gap-3">
              <%= user_avatar_image(
                    student,
                    size: 64,
                    class: "h-9 w-9 shrink-0 rounded-lg border border-slate-200 bg-slate-100 object-cover",
                    alt: "#{display_name(student)} avatar"
                  ) %>

              <div class="min-w-0">
                <div class="flex flex-wrap items-center gap-2">
                  <span class="truncate text-sm font-semibold text-slate-900"><%= display_name(student) %></span>
                  <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-semibold <%= membership.active? ? "bg-emerald-50 text-emerald-700" : "bg-slate-100 text-slate-600" %>">
                    <%= t("students.members.status.#{membership.status}") %>
                  </span>
                </div>
              </div>
            </div>

            <div class="flex flex-wrap items-center gap-2 md:justify-end">
              <%= link_to t("students.members.actions.account"),
                    edit_classroom_student_path(@classroom, student),
                    class: "inline-flex min-h-9 items-center justify-center rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-50 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-sky-500 focus-visible:ring-offset-2" %>

              <% if membership.active? %>
                <%= button_to t("students.actions.deactivate"),
                      deactivate_classroom_student_path(@classroom, student),
                      method: :patch,
                      data: { turbo_confirm: t("students.deactivate.confirm") },
                      class: "inline-flex min-h-9 items-center justify-center rounded-lg border border-rose-300 bg-white px-3 py-2 text-sm font-semibold text-rose-700 hover:bg-rose-50 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-rose-500 focus-visible:ring-offset-2" %>
              <% else %>
                <%= button_to t("students.actions.reactivate"),
                      reactivate_classroom_student_path(@classroom, student),
                      method: :patch,
                      class: "inline-flex min-h-9 items-center justify-center rounded-lg border border-emerald-300 bg-white px-3 py-2 text-sm font-semibold text-emerald-700 hover:bg-emerald-50 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-emerald-500 focus-visible:ring-offset-2" %>
              <% end %>
            </div>
          </article>
        <% end %>
      </div>
    <% else %>
      <div class="border border-dashed border-slate-300 bg-slate-50 px-4 py-5 text-center">
        <p class="text-sm text-slate-600"><%= t("students.members.empty_states.#{member_status}") %></p>
        <% if member_counts.fetch("all", 0).zero? %>
          <%= link_to t("ui.buttons.create_student"),
                new_classroom_student_path(@classroom, return_to: "members"),
                data: { turbo_frame: "modal" },
                class: "mt-3 inline-flex min-h-10 items-center justify-center rounded-lg bg-emerald-600 px-4 py-2 text-sm font-semibold text-white hover:bg-emerald-700 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-emerald-500 focus-visible:ring-offset-2" %>
        <% end %>
      </div>
    <% end %>
  </div>

</section>
