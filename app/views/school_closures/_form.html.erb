<%= form_with model: [school, school_closure], class: "space-y-5" do |f| %>
  <% %i[name starts_on ends_on].each do |attribute| %>
    <% has_errors = school_closure.errors[attribute].any? %>
    <div>
      <%= f.label attribute, t("school_closures.form.#{attribute}_label"), class: "block text-sm font-semibold text-slate-800" %>
      <% if attribute == :name %>
        <%= f.text_field attribute, autofocus: true, class: "mt-1 block w-full rounded-lg border px-3 py-2 text-sm shadow-sm #{has_errors ? "border-rose-400" : "border-slate-300"}" %>
      <% else %>
        <%= f.date_field attribute, class: "mt-1 block w-full rounded-lg border px-3 py-2 text-sm shadow-sm #{has_errors ? "border-rose-400" : "border-slate-300"}" %>
      <% end %>
      <% if has_errors %>
        <p class="mt-1 text-sm text-rose-600"><%= school_closure.errors.full_messages_for(attribute).to_sentence %></p>
      <% end %>
    </div>
  <% end %>

  <div class="flex items-center justify-end gap-3">
    <%= link_to t("school_closures.actions.back"), school_path(school), class: "rounded-lg border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-50" %>
    <%= f.submit t(school_closure.new_record? ? "school_closures.form.create_submit" : "school_closures.form.update_submit"),
          data: { turbo_submits_with: t("school_closures.form.submitting") },
          class: "rounded-lg bg-sky-600 px-4 py-2 text-sm font-semibold text-white hover:bg-sky-700" %>
  </div>
<% end %>
