<%= turbo_frame_tag :modal do %>
  <div class="fixed inset-0 z-50 flex items-center justify-center bg-black/50" data-controller="modal">
    <div class="relative w-full max-w-md rounded-2xl bg-white p-6 shadow-xl">
      <button type="button"
              data-action="modal#close"
              class="absolute right-3 top-2 text-2xl text-slate-400 hover:text-slate-600">&times;</button>

      <h2 class="text-xl font-bold text-slate-900">비밀번호 변경</h2>
      <p class="mt-1 text-sm text-slate-500">
        비밀번호 변경 시에만 현재 비밀번호를 확인합니다.
      </p>

      <%= simple_form_for(resource,
            as: resource_name,
            url: account_password_path,
            method: :patch,
            html: { class: "mt-5 space-y-4" }) do |f| %>
        <%= f.error_notification %>

        <%= f.input :current_password,
              required: true,
              input_html: {
                autocomplete: "current-password",
                class: "block w-full rounded-xl border border-slate-300 px-4 py-3 text-sm text-slate-900 shadow-sm placeholder:text-slate-400 focus:border-sky-500 focus:outline-none focus:ring-2 focus:ring-sky-100"
              },
              label_html: { class: "mb-2 block text-sm font-medium text-slate-700" } %>

        <%= f.input :password,
              required: true,
              input_html: {
                autocomplete: "new-password",
                class: "block w-full rounded-xl border border-slate-300 px-4 py-3 text-sm text-slate-900 shadow-sm placeholder:text-slate-400 focus:border-sky-500 focus:outline-none focus:ring-2 focus:ring-sky-100"
              },
              hint: (@minimum_password_length.present? ? "최소 #{@minimum_password_length}자 이상 입력하세요." : nil),
              label_html: { class: "mb-2 block text-sm font-medium text-slate-700" } %>

        <%= f.input :password_confirmation,
              required: true,
              input_html: {
                autocomplete: "new-password",
                class: "block w-full rounded-xl border border-slate-300 px-4 py-3 text-sm text-slate-900 shadow-sm placeholder:text-slate-400 focus:border-sky-500 focus:outline-none focus:ring-2 focus:ring-sky-100"
              },
              label_html: { class: "mb-2 block text-sm font-medium text-slate-700" } %>

        <div class="flex items-center justify-between gap-3 pt-2">
          <button type="button"
                  data-action="modal#close"
                  class="inline-flex items-center justify-center rounded-lg bg-slate-100 px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-200">
            닫기
          </button>

          <%= f.button :submit,
                "비밀번호 변경",
                class: "inline-flex items-center justify-center rounded-lg bg-blue-600 px-4 py-2 text-sm font-semibold text-white hover:bg-blue-700" %>
        </div>
      <% end %>
    </div>
  </div>
<% end %>
