<section class="mx-auto w-full max-w-6xl pt-4 space-y-6">
  <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
    <div class="flex flex-col items-start justify-between gap-3 sm:flex-row sm:items-center">
      <div class="flex items-center gap-4">
        <%= user_avatar_image(@user, size: 512,
              class: "h-24 w-24 rounded-2xl object-cover border border-slate-200 bg-slate-100",
              alt: "#{@user.name} avatar") %>
        <div>
          <h1 class="text-2xl font-extrabold tracking-tight text-slate-900">
            <%= @user.name %>
            <% if @visible_classrooms.any? %>
              <span class="ml-2 text-sm font-medium text-slate-500">
                <%= @visible_classrooms.map(&:name).join(", ") %>
              </span>
            <% end %>
          </h1>
          <%= turbo_frame_tag dom_id(@user, :kpis) do %>
            <%= render partial: "users/kpi_chips", locals: { user: @user, kpi_counts: @kpi_counts } %>
          <% end %>
        </div>
      </div>
      <div class="flex w-full flex-wrap items-center gap-2 sm:w-auto">
        <%= link_to "내 정보 수정",
              edit_user_registration_path,
              class: "inline-flex items-center rounded-lg border border-sky-300 bg-sky-50 px-3 py-2 text-sm font-semibold text-sky-700 hover:bg-sky-100" %>
      </div>
    </div>
  </div>

  <div class="space-y-6">
    <section class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
      <div class="flex items-center justify-between">
        <h2 class="text-base font-semibold text-slate-900">보유 쿠폰 (사용하기)</h2>
        <span class="text-xs text-slate-500">issued 기준</span>
      </div>
      <div class="mt-3">
        <%= turbo_frame_tag dom_id(@user, :coupons) do %>
          <%= render partial: "user_coupons/list", locals: { coupons: @coupons, user: @user } %>
        <% end %>
      </div>
    </section>

    <div class="mt-4 grid grid-cols-1 gap-4 md:grid-cols-2">
      <section class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
        <div class="flex items-center justify-between">
          <h2 class="text-base font-semibold text-slate-900">
            <%= t("titles.recent_issued_coupons_for_user", default: "최근 발급 쿠폰") %>
          </h2>
          <span class="text-xs text-slate-500">최신 순</span>
        </div>
        <div class="mt-3 max-h-[20rem] overflow-y-auto md:h-[28rem]">
          <%= turbo_frame_tag dom_id(@user, :recent_issued_coupons) do %>
            <%= render partial: "user_coupons/issued_coupons",
              locals: { coupons: @recent_issued_coupons, show_user: false } %>
          <% end %>
        </div>
      </section>
      <section class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
        <div class="flex items-center justify-between">
          <h2 class="text-base font-semibold text-slate-900">칭찬 타임라인</h2>
          <span class="text-xs text-slate-500">최근순</span>
        </div>
        <div class="mt-3 max-h-[20rem] overflow-y-auto md:h-[28rem]">
          <%= turbo_frame_tag dom_id(@user, :compliments) do %>
            <%= render partial: "users/compliments_timeline", locals: { compliments: @compliments } %>
          <% end %>
        </div>
      </section>
    </div>

    <%= render "user_messages/self_frame",
          dom_id: @message_section_dom_id,
          threads: @message_threads,
          reply_message: @reply_message,
          user: @user %>
  </div>
</section>
