<section class="mx-auto w-full max-w-6xl pt-4 space-y-6">
  <%# ===== Top actions ===== %>
  <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
    <div class="flex flex-col items-start justify-between gap-3 sm:flex-row sm:items-center">
      <div class="flex items-center gap-4">
        <%= user_avatar_image(@user, size: 512,
              class: "h-24 w-24 rounded-2xl object-cover border border-slate-200 bg-slate-100",
              alt: "#{@user.name} avatar") %>
        <div>
        <div class="flex flex-wrap items-center gap-3">
          <h1 class="text-2xl font-extrabold tracking-tight text-slate-900">
            <%= @user.name %>
            <% if @self_page && @visible_classrooms.any? %>
              <span class="ml-2 text-sm font-medium text-slate-500">
                <%= @visible_classrooms.map(&:name).join(", ") %>
              </span>
            <% elsif @classroom %>
              <span class="ml-2 text-sm font-medium text-slate-500">
                <%= @classroom.name %>
              </span>
            <% end %>
          </h1>
          <% if @managed_page && @can_destroy_student %>
            <%= link_to "계정 관리",
                  edit_classroom_student_path(@classroom, @user),
                  class: "inline-flex items-center rounded-lg border border-rose-300 bg-white px-3 py-1.5 text-sm font-semibold text-rose-700 hover:bg-rose-50" %>
          <% end %>
        </div>
        <%= turbo_frame_tag dom_id(@user, :kpis) do %>
          <%= render partial: "users/kpi_chips", locals: { user: @user, kpi_counts: @kpi_counts } %>
        <% end %>
        </div>
      </div>
      <div class="flex w-full flex-wrap items-center gap-2 sm:w-auto">
        <% if @self_page %>
          <%= link_to "내 정보 수정",
                edit_user_registration_path,
                class: "inline-flex items-center rounded-lg border border-sky-300 bg-sky-50 px-3 py-2 text-sm font-semibold text-sky-700 hover:bg-sky-100" %>
        <% end %>
        <% if @classroom %>
          <%= link_to t("ui.buttons.back_to_classroom", name: @classroom.name),
                      classroom_path(@classroom),
                      class: "inline-flex items-center rounded-lg bg-slate-100 px-3 py-2 text-sm text-slate-700 hover:bg-slate-200" %>
        <% end %>
        <% if @can_create_compliment %>
          <%= button_to t("ui.buttons.compliment"),
                classroom_compliments_path(@classroom),
                method: :post,
                params: { compliment: { receiver_id: @user.id } },
                form: {
                  data: {
                    controller: "disable-on-submit",
                    action: "turbo:submit-start->disable-on-submit#onSubmit turbo:submit-end->disable-on-submit#onTurboSubmitEnd",
                    turbo_submits_with: t("ui.processing")
                  },
                  aria: { busy: "false" }
                },
                class: "inline-flex items-center rounded-lg bg-amber-300 px-3 py-2 text-sm font-semibold text-amber-950 hover:bg-amber-400" %>
        <% end %>
        <% if @can_draw_coupon %>
          <%= button_to t("ui.buttons.issue_coupon_manual"),
                draw_coupon_classroom_path(
                  @classroom,
                  basis: "manual",
                  mode:  "default",
                  user_id: @user.id
                ),
                method: :post,
                form: {
                  data: {
                    controller: "disable-on-submit",
                    action: "turbo:submit-start->disable-on-submit#onSubmit turbo:submit-end->disable-on-submit#onTurboSubmitEnd",
                    turbo_submits_with: t("ui.processing")
                  },
                  aria: { busy: "false" }
                },
                class: "inline-flex items-center rounded-lg bg-blue-600 px-3 py-2 text-sm text-white hover:bg-blue-700" %>
        <% end %>
      </div>
    </div>
  </div>

  <%# ===== Main layout: 2 columns on desktop ===== %>
  <div class="space-y-6">
  <%# 보유 쿠폰: 먼저 전체 폭으로 %>
  <section class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
    <div class="flex items-center justify-between">
      <h2 class="text-base font-semibold text-slate-900">보유 쿠폰 (사용하기)</h2>
      <span class="text-xs text-slate-500">issued 기준</span>
    </div>
    <div class="mt-3">
      <%= turbo_frame_tag dom_id(@user, :coupons) do %>
        <%= render partial: "user_coupons/list", locals: { coupons: @coupons, user: @user } %>
      <% end %>
    </div>
  </section>
  <%# 아래: 최근 발급(좌) + 칭찬 타임라인(우) — PC 2열 / 모바일 1열 %>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-4">
    <section class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
      <div class="flex items-center justify-between">
        <h2 class="text-base font-semibold text-slate-900">
          <%= t("titles.recent_issued_coupons_for_user", default: "최근 발급 쿠폰") %>
        </h2>
        <span class="text-xs text-slate-500">최신 순</span>
      </div>
      <div class="mt-3">
        <%= turbo_frame_tag dom_id(@user, :recent_issued_coupons) do %>
          <%= render partial: "user_coupons/issued_coupons",
            locals: { coupons: @recent_issued_coupons, show_user: false } %>
        <% end %>
      </div>
    </section>
    <section class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
      <div class="flex items-center justify-between">
        <h2 class="text-base font-semibold text-slate-900">칭찬 타임라인</h2>
        <span class="text-xs text-slate-500">최근순</span>
      </div>
      <div class="mt-3">
        <%= turbo_frame_tag dom_id(@user, :compliments) do %>
          <%= render partial: "users/compliments_timeline", locals: { compliments: @compliments } %>
        <% end %>
      </div>
    </section>
  </div>
  </div>
</section>
