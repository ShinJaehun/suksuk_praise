<%= turbo_frame_tag dom_id(user) do %>
  <% pending_coupon_request_ids = local_assigns.fetch(:student_ids_with_pending_coupon_use_requests, []) %>
  <div class="h-full rounded-2xl border border-slate-200 bg-white p-4 shadow-sm">
    <div class="flex items-center gap-3">
      <%= user_avatar_image(user, size: 128,
            class: "h-12 w-12 rounded-xl object-cover border border-slate-200 bg-slate-100",
            alt: "#{display_name(user)} avatar") %>
      <p class="flex min-w-0 flex-wrap items-center gap-2 font-semibold text-slate-800">
        <%= link_to display_name(user),
                    classroom_student_path(classroom, user),
                    data: { turbo: false },
                    class: "text-sky-700 hover:underline" %>
        <% if pending_coupon_request_ids.include?(user.id) %>
          <span class="inline-flex items-center rounded-full bg-emerald-50 px-2 py-0.5 text-xs font-semibold text-emerald-700">
            쿠폰 요청
          </span>
        <% end %>
      </p>
    </div>

    <div class="mt-3 rounded-lg bg-slate-50 px-3 py-2">
      <div class="text-xs text-slate-500">칭찬(포인트)</div>
      <div class="text-2xl font-extrabold text-slate-900"><%= user.points %></div>
    </div>

    <% if policy(classroom).create_compliment? %>
      <%= button_to t("ui.buttons.compliment"),
                    classroom_compliments_path(classroom),
                    method: :post,
                    params: { compliment: { receiver_id: user.id } },
                    form: { data: { turbo_submits_with: "처리중..." } },
                    class: "mt-3 inline-flex w-full items-center justify-center rounded-lg bg-amber-300 px-3 py-2 text-sm font-semibold text-amber-950 hover:bg-amber-400" %>
    <% end %>
  </div>
<% end %>
